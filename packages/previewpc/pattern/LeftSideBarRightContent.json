    "rootId": "shellRoot",
    "elements": [
        {
            "id": "shellRoot",
            "component": "div",
            "props": {
                "className": "flex flex-col w-full h-screen bg-surface-container-lowest overflow-hidden"
            },
            "children": [
                "shellHeader",
                "shellBody"
            ]
        },
        {
            "id": "shellHeader",
            "component": "header",
            "props": {
                "className": "h-12 w-full bg-surface-container-highest shadow-sm z-10 shrink-0"
            },
            "children": [
                "ghMainContainer"
            ]
        },
        {
            "id": "shellBody",
            "component": "div",
            "props": {
                "className": "flex flex-1 w-full overflow-hidden"
            },
            "children": [
                "shellSidebar",
                "shellMain"
            ]
        },
        {
            "id": "shellSidebar",
            "component": "aside",
            "props": {
                "className": "w-[15.5rem] h-full bg-surface-container-highest border-r border-divider shrink-0"
            },
            "children": [
                "snSidebarHeader",
                "snSidebarDivider",
                "snSidebarMenuContainer"
            ]
        },
        {
            "id": "shellMain",
            "component": "main",
            "props": {
                "className": "flex-1 h-full overflow-y-auto p-page flex flex-col gap-section"
            },
            "children": [
                "mcaBreadcrumb",
                "mcaTableCard"
            ]
        },
        {
            "id": "ghMainContainer",
            "component": "div",
            "props": {
                "className": "flex items-center justify-between h-full px-gutter"
            },
            "children": [
                "ghLeftSection",
                "ghCenterSection",
                "ghRightSection"
            ]
        },
        {
            "id": "ghLeftSection",
            "component": "div",
            "props": {
                "className": "flex items-center gap-inline"
            },
            "children": [
                "ghLogoIcon",
                "ghSystemName"
            ]
        },
        {
            "id": "ghLogoIcon",
            "component": "Icon",
            "props": {
                "name": "network",
                "color": "primary",
                "shape": "square",
                "className": "w-6 h-6"
            }
        },
        {
            "id": "ghSystemName",
            "component": "span",
            "props": {
                "className": "text-lg font-bold text-on-surface",
                "value": "Product"
            }
        },
        {
            "id": "ghCenterSection",
            "component": "div",
            "props": {
                "className": "flex-1 flex justify-center"
            },
            "children": [
                "ghTopMenu"
            ]
        },
        {
            "id": "ghTopMenu",
            "component": "Menu",
            "props": {
                "mode": "horizontal",
                "selectedKeys": {
                    "path": "/ghSelectedKeys"
                },
                "items": {
                    "path": "/ghNavItems"
                },
                "className": "border-none bg-transparent"
            }
        },
        {
            "id": "ghRightSection",
            "component": "div",
            "props": {
                "className": "flex items-center gap-gutter"
            },
            "children": [
                "ghActionGroup",
                "ghUserDropdown"
            ]
        },
        {
            "id": "ghActionGroup",
            "component": "div",
            "props": {
                "className": "flex items-center gap-inline"
            },
            "children": [
                "ghSearchBtn",
                "ghHelpBtn",
                "ghMoreBtn"
            ]
        },
        {
            "id": "ghSearchBtn",
            "component": "Button",
            "props": {
                "icon": "search",
                "types": "link",
                "className": "text-on-surface-variant hover:text-primary"
            }
        },
        {
            "id": "ghHelpBtn",
            "component": "Button",
            "props": {
                "icon": "help-circle",
                "types": "link",
                "className": "text-on-surface-variant hover:text-primary"
            }
        },
        {
            "id": "ghMoreBtn",
            "component": "Button",
            "props": {
                "icon": "more-horizontal",
                "types": "link",
                "className": "text-on-surface-variant hover:text-primary"
            }
        },
        {
            "id": "ghUserDropdown",
            "component": "Dropdown",
            "props": {
                "menu": {
                    "path": "/ghUserMenu"
                },
                "placement": "bottomRight",
                "trigger": [
                    "hover"
                ]
            },
            "children": [
                "ghUserAvatarContainer"
            ]
        },
        {
            "id": "ghUserAvatarContainer",
            "component": "div",
            "props": {
                "className": "flex items-center gap-2 cursor-pointer hover:opacity-80 transition-opacity"
            },
            "children": [
                "ghUserAvatar"
            ]
        },
        {
            "id": "ghUserAvatar",
            "component": "img",
            "props": {
                "src": "https://randomuser.me/api/portraits/men/32.jpg",
                "className": "w-8 h-8 rounded-full border border-divider"
            }
        },
        {
            "id": "snSidebarHeader",
            "component": "div",
            "props": {
                "className": "px-inset py-stack flex items-center"
            },
            "children": [
                "snSidebarTitleText"
            ]
        },
        {
            "id": "snSidebarTitleText",
            "component": "span",
            "props": {
                "className": "text-lg font-bold text-on-surface",
                "value": {
                    "path": "/snSidebarTitle"
                }
            }
        },
        {
            "id": "snSidebarDivider",
            "component": "Divider",
            "props": {
                "className": "my-0"
            }
        },
        {
            "id": "snSidebarMenuContainer",
            "component": "div",
            "props": {
                "className": "flex-1 overflow-y-auto py-inline"
            },
            "children": [
                "snSidebarMenu"
            ]
        },
        {
            "id": "snSidebarMenu",
            "component": "Menu",
            "props": {
                "mode": "vertical",
                "selectedKeys": {
                    "path": "/snSelectedKeys"
                },
                "openKeys": {
                    "path": "/snOpenKeys"
                },
                "items": {
                    "path": "/snMenuItems"
                },
                "className": "border-none"
            }
        },
        {
            "id": "mcaBreadcrumb",
            "component": "Breadcrumb",
            "props": {
                "items": {
                    "path": "/mcaBreadcrumbPaths"
                }
            }
        },
        {
            "id": "mcaTableCard",
            "component": "div",
            "props": {
                "className": "bg-surface-container-highest rounded-xl shadow-card p-inset flex flex-col gap-gutter"
            },
            "children": [
                "mcaTableHeader",
                "mcaTableMain"
            ]
        },
        {
            "id": "mcaTableHeader",
            "component": "div",
            "props": {
                "className": "flex flex-col gap-stack"
            },
            "children": [
                "mcaTableTitle",
                "mcaTableActions"
            ]
        },
        {
            "id": "mcaTableTitle",
            "component": "span",
            "props": {
                "value": "设备列表",
                "className": "text-lg font-bold text-on-surface"
            }
        },
        {
            "id": "mcaTableActions",
            "component": "div",
            "props": {
                "className": "flex items-center justify-between"
            },
            "children": [
                "mcaSearchInput",
                "mcaActionGroup"
            ]
        },
        {
            "id": "mcaSearchInput",
            "component": "Input",
            "props": {
                "value": {
                    "path": "/mcaSearchValue"
                },
                "placeholder": "搜索设备名称或SN",
                "prefix": "search",
                "className": "w-80"
            }
        },
        {
            "id": "mcaActionGroup",
            "component": "div",
            "props": {
                "className": "flex items-center gap-inline"
            },
            "children": [
                "mcaBtnDownload",
                "mcaBtnPlay",
                "mcaBtnDelete",
                "mcaBtnMore",
                "mcaToolRefresh",
                "mcaToolSettings"
            ]
        },
        {
            "id": "mcaBtnDownload",
            "component": "Button",
            "props": {
                "value": "Download",
                "color": "default"
            }
        },
        {
            "id": "mcaBtnPlay",
            "component": "Button",
            "props": {
                "value": "Play",
                "color": "primary"
            }
        },
        {
            "id": "mcaBtnDelete",
            "component": "Button",
            "props": {
                "value": "Delete",
                "color": "danger"
            }
        },
        {
            "id": "mcaBtnMore",
            "component": "Button",
            "props": {
                "value": "More",
                "icon": "chevron-down",
                "iconPlacement": "end",
                "color": "default"
            }
        },
        {
            "id": "mcaToolRefresh",
            "component": "Button",
            "props": {
                "icon": "refresh-cw",
                "color": "default"
            }
        },
        {
            "id": "mcaToolSettings",
            "component": "Button",
            "props": {
                "icon": "settings",
                "color": "default"
            }
        },
        {
            "id": "mcaTableMain",
            "component": "Table",
            "props": {
                "rowKey": "id",
                "dataSource": {
                    "path": "/mcaDeviceList"
                },
                "columns": [
                    {
                        "title": "名称",
                        "dataIndex": "name",
                        "sort": true,
                        "minWidth": 200
                    },
                    {
                        "title": "站点",
                        "dataIndex": "site",
                        "sort": true
                    },
                    {
                        "title": "设备SN",
                        "dataIndex": "sn",
                        "sort": true
                    },
                    {
                        "title": "状态",
                        "dataIndex": "status"
                    },
                    {
                        "title": "操作",
                        "dataIndex": "actions",
                        "fixed": "end",
                        "width": 180
                    }
                ]
            },
            "children": {
                "path": "/mcaDeviceList",
                "componentId": "mcaTableRow"
            }
        },
        {
            "id": "mcaTableRow",
            "component": "TableRow",
            "children": [
                "mcaCellName",
                "mcaCellSite",
                "mcaCellSn",
                "mcaCellStatus",
                "mcaCellActions"
            ]
        },
        {
            "id": "mcaCellName",
            "component": "span",
            "props": {
                "value": {
                    "path": "name"
                },
                "className": "text-md font-medium"
            }
        },
        {
            "id": "mcaCellSite",
            "component": "span",
            "props": {
                "value": {
                    "path": "site"
                },
                "className": "text-md text-on-surface-variant"
            }
        },
        {
            "id": "mcaCellSn",
            "component": "span",
            "props": {
                "value": {
                    "path": "sn"
                },
                "className": "text-md font-mono"
            }
        },
        {
            "id": "mcaCellStatus",
            "component": "Tag",
            "props": {
                "value": {
                    "path": "status"
                },
                "color": {
                    "path": "statusColor"
                },
                "icon": {
                    "path": "statusIcon"
                },
                "variant": "outlined"
            }
        },
        {
            "id": "mcaCellActions",
            "component": "div",
            "props": {
                "className": "flex items-center gap-inline"
            },
            "children": [
                "mcaRowBtnSave",
                "mcaRowBtnDelete",
                "mcaRowBtnInfo",
                "mcaRowBtnMore"
            ]
        },
        {
            "id": "mcaRowBtnSave",
            "component": "Button",
            "props": {
                "icon": "save",
                "types": "link",
                "size": "small"
            }
        },
        {
            "id": "mcaRowBtnDelete",
            "component": "Button",
            "props": {
                "icon": "trash-2",
                "types": "link",
                "size": "small",
                "color": "danger"
            }
        },
        {
            "id": "mcaRowBtnInfo",
            "component": "Button",
            "props": {
                "icon": "alert-circle",
                "types": "link",
                "size": "small"
            }
        },
        {
            "id": "mcaRowBtnMore",
            "component": "Button",
            "props": {
                "icon": "more-horizontal",
                "types": "link",
                "size": "small"
            }
        }
    ]
}