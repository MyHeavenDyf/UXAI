{
  "rootId": "loginRootContainer",
  "elements": [
    {
      "id": "loginRootContainer",
      "component": "div",
      "props": {
        "className": "flex flex-col min-h-screen"
      },
      "children": [
        "loginMainArea",
        "loginFooterSection"
      ]
    },
    {
      "id": "loginMainArea",
      "component": "div",
      "props": {
        "className": "flex-1 flex flex-row w-full bg-gradient-to-r from-inverse-surface to-surface-container-lowest"
      },
      "children": [
        "loginBrandSection",
        "loginFormSection"
      ]
    },
    {
      "id": "loginBrandSection",
      "component": "section",
      "props": {
        "className": "w-[45%] flex flex-col items-center justify-center px-page py-page"
      },
      "children": [
        "brndContentStack"
      ]
    },
    {
      "id": "loginFormSection",
      "component": "section",
      "props": {
        "className": "w-[55%] flex items-center justify-center"
      },
      "children": [
        "formCardContainer"
      ]
    },
    {
      "id": "loginFooterSection",
      "component": "footer",
      "props": {
        "className": "w-full bg-inverse-surface/80 backdrop-blur-sm px-page py-stack"
      },
      "children": [
        "footContentContainer"
      ]
    },
    {
      "id": "brndContentStack",
      "component": "div",
      "props": {
        "className": "w-full max-w-lg flex flex-col items-center gap-8"
      },
      "children": [
        "brndLogoSystemGroup",
        "brndSloganText",
        "brndCarouselArea",
        "brndSecurityRow",
        "brndVersionBadge"
      ]
    },
    {
      "id": "brndLogoSystemGroup",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center gap-2"
      },
      "children": [
        "brndLogoRow",
        "brndSystemFullName"
      ]
    },
    {
      "id": "brndLogoRow",
      "component": "div",
      "props": {
        "className": "flex items-center gap-3"
      },
      "children": [
        "brndLogoImg",
        "brndSystemName"
      ]
    },
    {
      "id": "brndLogoImg",
      "component": "img",
      "props": {
        "src": {
          "path": "/brandLogoImage"
        },
        "alt": "CloudForge Logo",
        "className": "h-10 w-auto"
      }
    },
    {
      "id": "brndSystemName",
      "component": "span",
      "props": {
        "value": {
          "path": "/systemName"
        },
        "className": "text-3xl font-bold text-white tracking-wide"
      }
    },
    {
      "id": "brndSystemFullName",
      "component": "span",
      "props": {
        "value": {
          "path": "/systemFullName"
        },
        "className": "text-sm text-white/50 tracking-wide"
      }
    },
    {
      "id": "brndSloganText",
      "component": "p",
      "props": {
        "value": {
          "path": "/systemSlogan"
        },
        "className": "text-lg text-white/70 text-center leading-relaxed"
      }
    },
    {
      "id": "brndCarouselArea",
      "component": "div",
      "props": {
        "className": "w-full"
      },
      "children": [
        "brndCarousel"
      ]
    },
    {
      "id": "brndCarousel",
      "component": "Carousel",
      "props": {
        "autoplay": {
          "path": "/carouselConfig/autoPlayEnabled"
        },
        "autoplaySpeed": 4000,
        "dots": {
          "path": "/carouselConfig/showIndicators"
        },
        "arrows": {
          "path": "/carouselConfig/showArrows"
        }
      },
      "children": {
        "path": "/brandCarouselSlides",
        "componentId": "brndCarouselSlideItem"
      }
    },
    {
      "id": "brndCarouselSlideItem",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center gap-4 p-4"
      },
      "children": [
        "brndSlideImage",
        "brndSlideTitle",
        "brndSlideDesc"
      ]
    },
    {
      "id": "brndSlideImage",
      "component": "img",
      "props": {
        "src": {
          "path": "slideImage"
        },
        "alt": {
          "path": "slideTitle"
        },
        "className": "w-full h-auto rounded-xl shadow-lg"
      }
    },
    {
      "id": "brndSlideTitle",
      "component": "span",
      "props": {
        "value": {
          "path": "slideTitle"
        },
        "className": "text-xl font-semibold text-white"
      }
    },
    {
      "id": "brndSlideDesc",
      "component": "p",
      "props": {
        "value": {
          "path": "slideDescription"
        },
        "className": "text-sm text-white/60 text-center leading-relaxed"
      }
    },
    {
      "id": "brndSecurityRow",
      "component": "div",
      "props": {
        "className": "flex items-center gap-2"
      },
      "children": [
        "brndSecurityIcon",
        "brndSecurityText"
      ]
    },
    {
      "id": "brndSecurityIcon",
      "component": "Icon",
      "props": {
        "name": {
          "path": "/securityCertificationIcon"
        },
        "size": "w-5",
        "shape": "outline",
        "color": "success"
      }
    },
    {
      "id": "brndSecurityText",
      "component": "span",
      "props": {
        "value": {
          "path": "/securityCertificationText"
        },
        "className": "text-sm text-white/60"
      }
    },
    {
      "id": "brndVersionBadge",
      "component": "span",
      "props": {
        "value": {
          "path": "/versionBadge"
        },
        "className": "text-xs text-white/40 border border-white/10 px-3 py-1 rounded-full"
      }
    },
    {
      "id": "formCardContainer",
      "component": "div",
      "props": {
        "className": "bg-surface-container-highest shadow-sm rounded-xl p-8 w-full max-w-[420px]"
      },
      "children": [
        "formCardHeader",
        "formLoginTabs",
        "formOptionsRow",
        "formSubmitBtn",
        "formSocialDivider",
        "formSocialLoginSection",
        "formRegisterLink"
      ]
    },
    {
      "id": "formCardHeader",
      "component": "div",
      "props": {
        "className": "mb-7"
      },
      "children": [
        "formCardTitle",
        "formWelcomeTitle",
        "formWelcomeSub",
        "formSecurityNotice"
      ]
    },
    {
      "id": "formCardTitle",
      "component": "span",
      "props": {
        "className": "block text-xs font-medium text-on-surface-variant uppercase tracking-wider mb-1",
        "value": "用户登录"
      }
    },
    {
      "id": "formWelcomeTitle",
      "component": "h2",
      "props": {
        "className": "text-2xl font-bold text-on-surface mb-1",
        "value": "欢迎回来"
      }
    },
    {
      "id": "formWelcomeSub",
      "component": "p",
      "props": {
        "className": "text-sm text-on-surface-variant mb-4",
        "value": "请登录您的账号以继续使用 CloudForge 平台"
      }
    },
    {
      "id": "formSecurityNotice",
      "component": "div",
      "props": {
        "className": "flex items-start gap-2 bg-warning-container text-on-warning-container text-xs px-3 py-2.5 rounded-lg"
      },
      "children": [
        "formSecurityIcon",
        "formSecurityText"
      ]
    },
    {
      "id": "formSecurityIcon",
      "component": "Icon",
      "props": {
        "name": "ShieldCheck",
        "size": 14,
        "className": "mt-0.5 shrink-0 text-warning"
      }
    },
    {
      "id": "formSecurityText",
      "component": "span",
      "props": {
        "value": "您将进入企业管理系统，非授权访问将被记录并追责"
      }
    },
    {
      "id": "formLoginTabs",
      "component": "Tabs",
      "props": {
        "activeKey": {
          "path": "/activeTabKey"
        },
        "centered": true,
        "className": "mb-6"
      },
      "children": [
        "formAccountTabItem",
        "formSmsTabItem"
      ]
    },
    {
      "id": "formAccountTabItem",
      "component": "TabItem",
      "props": {
        "key": "accountLogin",
        "label": "账号登录",
        "icon": "User",
        "content": {
          "componentId": "formAccountPanel"
        }
      }
    },
    {
      "id": "formAccountPanel",
      "component": "div",
      "props": {
        "className": "pt-2"
      },
      "children": [
        "formAccountField",
        "formPasswordField"
      ]
    },
    {
      "id": "formAccountField",
      "component": "div",
      "props": {
        "className": "mb-4"
      },
      "children": [
        "formAccountLabel",
        "formAccountInput"
      ]
    },
    {
      "id": "formAccountLabel",
      "component": "label",
      "props": {
        "className": "block text-sm font-medium text-on-surface mb-1.5",
        "value": "用户名 / 手机号 / 邮箱"
      }
    },
    {
      "id": "formAccountInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/account"
        },
        "placeholder": "请输入用户名、手机号或邮箱",
        "prefix": "User",
        "autoComplete": "username",
        "className": "w-full",
        "size": "large"
      }
    },
    {
      "id": "formPasswordField",
      "component": "div",
      "props": {
        "className": "mb-2"
      },
      "children": [
        "formPasswordLabel",
        "formPasswordInput"
      ]
    },
    {
      "id": "formPasswordLabel",
      "component": "label",
      "props": {
        "className": "block text-sm font-medium text-on-surface mb-1.5",
        "value": "密码"
      }
    },
    {
      "id": "formPasswordInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/password"
        },
        "placeholder": "请输入密码",
        "prefix": "Lock",
        "type": "password",
        "autoComplete": "current-password",
        "className": "w-full",
        "size": "large"
      }
    },
    {
      "id": "formSmsTabItem",
      "component": "TabItem",
      "props": {
        "key": "smsLogin",
        "label": "短信登录",
        "icon": "MessageSquare",
        "content": {
          "componentId": "formSmsPanel"
        }
      }
    },
    {
      "id": "formSmsPanel",
      "component": "div",
      "props": {
        "className": "pt-2"
      },
      "children": [
        "formPhoneField",
        "formSmsCodeField"
      ]
    },
    {
      "id": "formPhoneField",
      "component": "div",
      "props": {
        "className": "mb-4"
      },
      "children": [
        "formPhoneLabel",
        "formPhoneInput"
      ]
    },
    {
      "id": "formPhoneLabel",
      "component": "label",
      "props": {
        "className": "block text-sm font-medium text-on-surface mb-1.5",
        "value": "手机号"
      }
    },
    {
      "id": "formPhoneInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/phoneNumber"
        },
        "placeholder": "请输入11位手机号",
        "prefix": "Smartphone",
        "maxLength": 11,
        "autoComplete": "tel",
        "className": "w-full",
        "size": "large"
      }
    },
    {
      "id": "formSmsCodeField",
      "component": "div",
      "props": {
        "className": "mb-2"
      },
      "children": [
        "formSmsCodeLabel",
        "formSmsCodeRow"
      ]
    },
    {
      "id": "formSmsCodeLabel",
      "component": "label",
      "props": {
        "className": "block text-sm font-medium text-on-surface mb-1.5",
        "value": "验证码"
      }
    },
    {
      "id": "formSmsCodeRow",
      "component": "div",
      "props": {
        "className": "flex gap-3"
      },
      "children": [
        "formSmsCodeInput",
        "formSmsCodeBtn"
      ]
    },
    {
      "id": "formSmsCodeInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/smsCode"
        },
        "placeholder": "请输入6位验证码",
        "prefix": "KeyRound",
        "maxLength": 6,
        "autoComplete": "one-time-code",
        "className": "flex-1",
        "size": "large"
      }
    },
    {
      "id": "formSmsCodeBtn",
      "component": "Button",
      "props": {
        "value": "获取验证码",
        "className": "shrink-0",
        "size": "large"
      }
    },
    {
      "id": "formOptionsRow",
      "component": "div",
      "props": {
        "className": "flex items-center justify-start mb-6 mt-2"
      },
      "children": [
        "formRememberCheckbox",
        "formForgotPwdAnchor"
      ]
    },
    {
      "id": "formRememberCheckbox",
      "component": "Checkbox",
      "props": {
        "checked": {
          "path": "/rememberMe"
        },
        "value": "记住账号"
      }
    },
    {
      "id": "formForgotPwdAnchor",
      "component": "a",
      "props": {
        "href": "/forgot-password",
        "className": "text-sm text-primary hover:text-primary-fixed-dim transition-colors inline-flex items-center gap-1",
        "target": "_self"
      },
      "children": [
        "formForgotPwdIcon",
        "formForgotPwdText"
      ]
    },
    {
      "id": "formForgotPwdIcon",
      "component": "Icon",
      "props": {
        "name": "HelpCircle",
        "size": 14,
        "className": "text-primary"
      }
    },
    {
      "id": "formForgotPwdText",
      "component": "span",
      "props": {
        "value": "忘记密码？"
      }
    },
    {
      "id": "formSubmitBtn",
      "component": "Button",
      "props": {
        "value": "登 录",
        "icon": "LogIn",
        "type": "primary",
        "shape": "round",
        "block": true,
        "className": "h-11 text-base font-medium mb-6",
        "size": "large"
      }
    },
    {
      "id": "formSocialDivider",
      "component": "Divider",
      "props": {
        "value": "或使用以下方式登录",
        "className": "mb-6 text-sm text-on-surface-variant"
      }
    },
    {
      "id": "formSocialLoginSection",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center gap-5 mb-6"
      },
      "children": [
        "formSocialIcons",
        "formQrCodeSection"
      ]
    },
    {
      "id": "formSocialIcons",
      "component": "div",
      "props": {
        "className": "flex items-center justify-center gap-5"
      },
      "children": [
        "formWechatBtn",
        "formDingtalkBtn",
        "formWorkwechatBtn",
        "formFeishuBtn"
      ]
    },
    {
      "id": "formWechatBtn",
      "component": "Button",
      "props": {
        "icon": "MessageCircle",
        "shape": "circle",
        "size": "large"
      }
    },
    {
      "id": "formDingtalkBtn",
      "component": "Button",
      "props": {
        "icon": "Bell",
        "shape": "circle",
        "size": "large"
      }
    },
    {
      "id": "formWorkwechatBtn",
      "component": "Button",
      "props": {
        "icon": "Briefcase",
        "shape": "circle",
        "size": "large"
      }
    },
    {
      "id": "formFeishuBtn",
      "component": "Button",
      "props": {
        "icon": "BookOpen",
        "shape": "circle",
        "disabled": true,
        "size": "large"
      }
    },
    {
      "id": "formQrCodeSection",
      "component": "div",
      "props": {
        "className": "flex items-center gap-2"
      },
      "children": [
        "formQrCodeBtn"
      ]
    },
    {
      "id": "formQrCodeBtn",
      "component": "Button",
      "props": {
        "icon": "QrCode",
        "value": "扫码登录",
        "shape": "round",
        "className": "text-sm",
        "size": "large"
      }
    },
    {
      "id": "formRegisterLink",
      "component": "a",
      "props": {
        "href": "/register",
        "className": "block text-center text-sm text-primary hover:text-primary-fixed-dim font-medium inline-flex items-center justify-center gap-1",
        "target": "_self"
      },
      "children": [
        "formRegisterIcon",
        "formRegisterText"
      ]
    },
    {
      "id": "formRegisterIcon",
      "component": "Icon",
      "props": {
        "name": "UserPlus",
        "size": 14,
        "className": "text-primary"
      }
    },
    {
      "id": "formRegisterText",
      "component": "span",
      "props": {
        "value": "还没有账号？立即注册"
      }
    },
    {
      "id": "footContentContainer",
      "component": "div",
      "props": {
        "className": "mx-auto max-w-6xl flex flex-col items-center gap-stack w-full"
      },
      "children": [
        "footDivider",
        "footLinkGroupsRow",
        "footCopyrightRow",
        "footIcpRow"
      ]
    },
    {
      "id": "footDivider",
      "component": "Divider",
      "props": {
        "className": "border-inverse-on-surface-variant/20 w-full"
      }
    },
    {
      "id": "footLinkGroupsRow",
      "component": "div",
      "props": {
        "className": "w-full flex justify-center gap-gutter"
      },
      "children": {
        "path": "/footerLinkGroups",
        "componentId": "footGroupItem"
      }
    },
    {
      "id": "footGroupItem",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center gap-1"
      },
      "children": [
        "footGroupHeader",
        "footGroupLinksList"
      ]
    },
    {
      "id": "footGroupHeader",
      "component": "div",
      "props": {
        "className": "flex items-center gap-1 mb-1"
      },
      "children": [
        "footGroupIconEl",
        "footGroupTitle"
      ]
    },
    {
      "id": "footGroupIconEl",
      "component": "Icon",
      "props": {
        "shape": "outline",
        "size": 14,
        "color": "inverse",
        "name": {
          "path": "groupIcon"
        }
      }
    },
    {
      "id": "footGroupTitle",
      "component": "span",
      "props": {
        "className": "text-sm font-semibold text-inverse-on-surface",
        "value": {
          "path": "groupName"
        }
      }
    },
    {
      "id": "footGroupLinksList",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center gap-0.5"
      },
      "children": {
        "path": "links",
        "componentId": "footLinkItem"
      }
    },
    {
      "id": "footLinkItem",
      "component": "div",
      "props": {
        "className": "flex items-center gap-1"
      },
      "children": [
        "footLinkBtn"
      ]
    },
    {
      "id": "footLinkBtn",
      "component": "Button",
      "props": {
        "type": "link",
        "className": "text-inverse-on-surface-variant hover:text-inverse-on-surface",
        "value": {
          "path": "linkLabel"
        },
        "icon": {
          "path": "linkIcon"
        },
        "href": {
          "path": "linkUrl"
        },
        "target": "_blank"
      }
    },
    {
      "id": "footCopyrightRow",
      "component": "div",
      "props": {
        "className": "flex items-center justify-center"
      },
      "children": [
        "footCopyrightText"
      ]
    },
    {
      "id": "footCopyrightText",
      "component": "span",
      "props": {
        "className": "text-sm text-inverse-on-surface-variant",
        "value": {
          "path": "/copyrightInfo/displayLine"
        }
      }
    },
    {
      "id": "footIcpRow",
      "component": "div",
      "props": {
        "className": "flex items-center justify-center"
      },
      "children": [
        "footIcpLink"
      ]
    },
    {
      "id": "footIcpLink",
      "component": "Button",
      "props": {
        "type": "link",
        "className": "text-inverse-on-surface-variant hover:text-inverse-on-surface",
        "value": {
          "path": "/icpBeian/icpNumber"
        },
        "href": {
          "path": "/icpBeian/icpLinkUrl"
        },
        "target": "_blank"
      }
    }
  ],
  "state": {
    "brandLogoImage": "https://fpoimg.com/240x60?gradient=0067D1,004EA8&text_color=ffffff&text=CloudForge",
    "systemName": "CloudForge",
    "systemFullName": "CloudForge 企业智能管理平台",
    "systemSlogan": "驱动数字化转型 · 赋能业务创新",
    "versionBadge": "v4.2.0",
    "securityCertificationIcon": "ShieldCheck",
    "securityCertificationText": "ISO 27001 认证 · 等保三级",
    "carouselConfig": {
      "autoPlayEnabled": true,
      "intervalSeconds": 4,
      "showIndicators": true,
      "indicatorStyle": "dot",
      "showArrows": false
    },
    "brandCarouselSlides": [
      {
        "slideImage": "https://fpoimg.com/800x600?gradient=0067D1,004EA8&text_color=ffffff&text=智能数据看板",
        "slideTitle": "智能数据看板",
        "slideDescription": "实时洞察业务核心指标，自助式数据分析，让决策有据可依"
      },
      {
        "slideImage": "https://fpoimg.com/800x600?gradient=09AA71,0067D1&text_color=ffffff&text=流程自动化",
        "slideTitle": "流程自动化引擎",
        "slideDescription": "可视化编排业务流程，智能审批路由，大幅提升组织运营效率"
      },
      {
        "slideImage": "https://fpoimg.com/800x600?gradient=F4840C,FCC800&text_color=ffffff&text=协同办公",
        "slideTitle": "协同办公空间",
        "slideDescription": "融合即时通讯、文档协作与项目管理，打造高效团队工作台"
      },
      {
        "slideImage": "https://fpoimg.com/800x600?gradient=0067D1,09AA71&text_color=ffffff&text=安全合规",
        "slideTitle": "全方位安全合规",
        "slideDescription": "端到端数据加密、细粒度权限管控、完整审计日志，护航企业数据安全"
      }
