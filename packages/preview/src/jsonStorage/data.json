    },
    {
      "id": "altcRefreshBtn",
      "component": "Button",
      "props": {
        "icon": "refresh-cw",
        "shape": "circle"
      }
    },
    {
      "id": "altcTable",
      "component": "Table",
      "props": {
        "rowKey": "key",
        "dataSource": {
          "path": "/altcTableRows"
        },
        "rowSelection": {
          "type": "checkbox",
          "selectedRowKeys": {
            "path": "/altcSelectedRowKeys"
          }
        },
        "columns": [
          {
            "title": "名称",
            "dataIndex": "name",
            "minWidth": 160
          },
          {
            "title": "级别",
            "dataIndex": "level"
          },
          {
            "title": "详情",
            "dataIndex": "detail",
            "minWidth": 220
          },
          {
            "title": "站点",
            "dataIndex": "site"
          },
          {
            "title": "告警源分类",
            "dataIndex": "alertSourceCategory"
          },
          {
            "title": "告警源",
            "dataIndex": "alertSource",
            "minWidth": 180
          },
          {
            "title": "设备SN",
            "dataIndex": "deviceSN"
          },
          {
            "title": "首次发生时间",
            "dataIndex": "firstOccurTime",
            "sort": true,
            "minWidth": 160
          },
          {
            "title": "末次发生时间",
            "dataIndex": "lastOccurTime",
            "sort": true,
            "minWidth": 160
          },
          {
            "title": "是否确认",
            "dataIndex": "ackStatusText"
          },
          {
            "title": "处理策略",
            "dataIndex": "processStrategy"
          },
          {
            "title": "操作",
            "dataIndex": "actions",
            "fixed": "end",
            "width": 120
          }
        ],
        "className": "mb-4"
      },
      "children": {
        "path": "/altcTableRows",
        "componentId": "altcTableRow"
      }
