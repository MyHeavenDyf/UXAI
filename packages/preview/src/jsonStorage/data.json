{
  "rootId": "loginPageRoot",
  "elements": [
    {
      "id": "loginPageRoot",
      "component": "div",
      "props": {
        "className": "flex flex-col min-h-screen bg-surface-container-lowest"
      },
      "children": [
        "loginMainRow",
        "loginFooterSection"
      ]
    },
    {
      "id": "loginMainRow",
      "component": "div",
      "props": {
        "className": "flex-1 grid grid-cols-5"
      },
      "children": [
        "loginBrandSection",
        "loginFormSection"
      ]
    },
    {
      "id": "loginBrandSection",
      "component": "div",
      "props": {
        "className": "col-span-2 flex flex-col justify-center items-center overflow-hidden"
      },
      "children": [
        "brndWrapper"
      ]
    },
    {
      "id": "loginFormSection",
      "component": "div",
      "props": {
        "className": "col-span-3 flex flex-col justify-center items-center bg-surface-container-highest"
      },
      "children": [
        "lgnFrmFormCard",
        "lgnFrmFooterRow"
      ]
    },
    {
      "id": "loginFooterSection",
      "component": "div",
      "props": {
        "className": "flex items-center justify-between px-page py-gutter bg-surface-container-highest"
      },
      "children": [
        "ftrCopyrightBlock",
        "ftrRightBlock"
      ]
    },
    {
      "id": "brndWrapper",
      "component": "div",
      "props": {
        "className": "relative w-full h-full"
      },
      "children": [
        "brndBgImage",
        "brndOverlay",
        "brndContentWrap"
      ]
    },
    {
      "id": "brndBgImage",
      "component": "img",
      "props": {
        "src": {
          "path": "/backgroundImage"
        },
        "className": "absolute inset-0 w-full h-full object-cover",
        "alt": "品牌背景"
      }
    },
    {
      "id": "brndOverlay",
      "component": "div",
      "props": {
        "className": "absolute inset-0 bg-gradient-to-br from-black/60 via-black/40 to-black/60"
      }
    },
    {
      "id": "brndContentWrap",
      "component": "div",
      "props": {
        "className": "relative z-10 flex flex-col items-center px-12"
      },
      "children": [
        "brndLogoWrap",
        "brndBrandTitle",
        "brndBrandSlogan",
        "brndDivider",
        "brndFeatureList"
      ]
    },
    {
      "id": "brndLogoWrap",
      "component": "div",
      "props": {
        "className": "mb-8"
      },
      "children": [
        "brndLogoImg"
      ]
    },
    {
      "id": "brndLogoImg",
      "component": "img",
      "props": {
        "src": {
          "path": "/brandLogoImage"
        },
        "className": "w-24 h-24 object-contain drop-shadow-lg",
        "alt": "企业Logo"
      }
    },
    {
      "id": "brndBrandTitle",
      "component": "span",
      "props": {
        "className": "text-4xl font-bold text-white tracking-wide",
        "value": {
          "path": "/brandName"
        }
      }
    },
    {
      "id": "brndBrandSlogan",
      "component": "span",
      "props": {
        "className": "text-lg text-white/70 mt-3",
        "value": {
          "path": "/brandSlogan"
        }
      }
    },
    {
      "id": "brndDivider",
      "component": "div",
      "props": {
        "className": "w-16 h-0.5 bg-primary/80 mt-6 rounded-full"
      }
    },
    {
      "id": "brndFeatureList",
      "component": "div",
      "props": {
        "className": "flex gap-8 mt-8"
      },
      "children": {
        "path": "/brandFeatures",
        "componentId": "brndFeatItem"
      }
    },
    {
      "id": "brndFeatItem",
      "component": "div",
      "props": {
        "className": "flex items-center gap-2.5"
      },
      "children": [
        "brndFeatIcon",
        "brndFeatText"
      ]
    },
    {
      "id": "brndFeatIcon",
      "component": "Icon",
      "props": {
        "name": {
          "path": "iconName"
        },
        "color": "inverse",
        "shape": "outline",
        "className": "w-5 h-5"
      }
    },
    {
      "id": "brndFeatText",
      "component": "span",
      "props": {
        "className": "text-sm text-white/80",
        "value": {
          "path": "featureText"
        }
      }
    },
    {
      "id": "lgnFrmFormCard",
      "component": "div",
      "props": {
        "className": "w-full max-w-md p-inset bg-surface-bright shadow-card rounded-xl"
      },
      "children": [
        "lgnFrmCardTitle",
        "lgnFrmFormTitle",
        "lgnFrmFormSubtitle",
        "lgnFrmUsernameField",
        "lgnFrmPasswordField",
        "lgnFrmCaptchaField",
        "lgnFrmOptionsRow",
        "lgnFrmLoginBtn",
        "lgnFrmRegisterRow",
        "lgnFrmDivider",
        "lgnFrmSsoRow"
      ]
    },
    {
      "id": "lgnFrmCardTitle",
      "component": "span",
      "props": {
        "className": "text-sm font-medium text-primary mb-1",
        "value": {
          "path": "/lgnFrmCardTitle"
        }
      }
    },
    {
      "id": "lgnFrmFormTitle",
      "component": "h2",
      "props": {
        "className": "text-2xl font-bold text-on-surface mb-1",
        "value": {
          "path": "/lgnFrmFormTitle"
        }
      }
    },
    {
      "id": "lgnFrmFormSubtitle",
      "component": "p",
      "props": {
        "className": "text-md text-on-surface-variant mb-6",
        "value": {
          "path": "/lgnFrmFormSubtitle"
        }
      }
    },
    {
      "id": "lgnFrmUsernameField",
      "component": "div",
      "props": {
        "className": "flex flex-col gap-1 mb-stack"
      },
      "children": [
        "lgnFrmUsernameLabel",
        "lgnFrmUsernameInput"
      ]
    },
    {
      "id": "lgnFrmUsernameLabel",
      "component": "span",
      "props": {
        "className": "text-sm font-medium text-on-surface",
        "value": "用户名"
      }
    },
    {
      "id": "lgnFrmUsernameInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/lgnFrmUsername"
        },
        "placeholder": "请输入邮箱或手机号",
        "prefix": "user",
        "className": "w-full"
      }
    },
    {
      "id": "lgnFrmPasswordField",
      "component": "div",
      "props": {
        "className": "flex flex-col gap-1 mb-stack"
      },
      "children": [
        "lgnFrmPasswordLabel",
        "lgnFrmPasswordInput"
      ]
    },
    {
      "id": "lgnFrmPasswordLabel",
      "component": "span",
      "props": {
        "className": "text-sm font-medium text-on-surface",
        "value": "密码"
      }
    },
    {
      "id": "lgnFrmPasswordInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/lgnFrmPassword"
        },
        "placeholder": "请输入密码",
        "password": true,
        "prefix": "lock",
        "className": "w-full"
      }
    },
    {
      "id": "lgnFrmCaptchaField",
      "component": "div",
      "props": {
        "className": "flex flex-col gap-1 mb-stack"
      },
      "children": [
        "lgnFrmCaptchaLabel",
        "lgnFrmCaptchaRow"
      ]
    },
    {
      "id": "lgnFrmCaptchaLabel",
      "component": "span",
      "props": {
        "className": "text-sm font-medium text-on-surface",
        "value": "验证码"
      }
    },
    {
      "id": "lgnFrmCaptchaRow",
      "component": "div",
      "props": {
        "className": "flex gap-2 items-center"
      },
      "children": [
        "lgnFrmCaptchaInput",
        "lgnFrmCaptchaImg"
      ]
    },
    {
      "id": "lgnFrmCaptchaInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/lgnFrmCaptcha"
        },
        "placeholder": "输入验证码",
        "prefix": "shield",
        "className": "flex-1"
      }
    },
    {
      "id": "lgnFrmCaptchaImg",
      "component": "img",
      "props": {
        "src": {
          "path": "/lgnFrmCaptchaImage"
        },
        "className": "h-10 w-auto rounded-md cursor-pointer border border-base",
        "alt": "验证码图片"
      }
    },
    {
      "id": "lgnFrmOptionsRow",
      "component": "div",
      "props": {
        "className": "flex items-center justify-between mb-stack"
      },
      "children": [
        "lgnFrmRememberMeCheckbox",
        "lgnFrmForgotPwdBtn"
      ]
    },
    {
      "id": "lgnFrmRememberMeCheckbox",
      "component": "Checkbox",
      "props": {
        "checked": {
          "path": "/lgnFrmRememberMe"
        },
        "label": {
          "path": "/lgnFrmRememberMeText"
        }
      }
    },
    {
      "id": "lgnFrmForgotPwdBtn",
      "component": "Button",
      "props": {
        "value": {
          "path": "/lgnFrmForgotPwdText"
        },
        "types": "link",
        "color": "primary"
      }
    },
    {
      "id": "lgnFrmLoginBtn",
      "component": "Button",
      "props": {
        "value": {
          "path": "/lgnFrmLoginBtnText"
        },
        "color": "primary",
        "className": "w-full h-10 mb-stack"
      }
    },
    {
      "id": "lgnFrmRegisterRow",
      "component": "div",
      "props": {
        "className": "flex justify-center mb-section"
      },
      "children": [
        "lgnFrmRegisterBtn"
      ]
    },
    {
      "id": "lgnFrmRegisterBtn",
      "component": "Button",
      "props": {
        "value": {
          "path": "/lgnFrmRegisterText"
        },
        "types": "link",
        "color": "primary"
      }
    },
    {
      "id": "lgnFrmDivider",
      "component": "Divider",
      "props": {
        "value": "其他登录方式",
        "className": "mb-stack"
      }
    },
    {
      "id": "lgnFrmSsoRow",
      "component": "div",
      "props": {
        "className": "flex justify-center gap-4"
      },
      "children": {
        "path": "/lgnFrmSsoOptions",
        "componentId": "lgnFrmSsoItem"
      }
    },
    {
      "id": "lgnFrmSsoItem",
      "component": "Button",
      "props": {
        "icon": {
          "path": "iconName"
        },
        "shape": "circle",
        "className": "w-10 h-10"
      }
    },
    {
      "id": "lgnFrmFooterRow",
      "component": "div",
      "props": {
        "className": "flex justify-center gap-4 mt-section"
      },
      "children": {
        "path": "/lgnFrmAdditionalLinks",
        "componentId": "lgnFrmFooterItem"
      }
    },
    {
      "id": "lgnFrmFooterItem",
      "component": "Button",
      "props": {
        "value": {
          "path": "text"
        },
        "types": "link",
        "className": "text-sm text-on-surface-variant"
      }
    },
    {
      "id": "ftrCopyrightBlock",
      "component": "div",
      "props": {
        "className": "flex items-center"
      },
      "children": [
        "ftrCopyrightText"
      ]
    },
    {
      "id": "ftrCopyrightText",
      "component": "span",
      "props": {
        "value": "© 2026 A2Cloud. All rights reserved.",
        "className": "text-sm text-on-surface-variant"
      }
    },
    {
      "id": "ftrRightBlock",
      "component": "div",
      "props": {
        "className": "flex items-center gap-6"
      },
      "children": [
        "ftrLanguageSelect",
        "ftrLegalLinksBlock"
      ]
    },
    {
      "id": "ftrLanguageSelect",
      "component": "Select",
      "props": {
        "value": {
          "path": "/selectedLanguage"
        },
        "options": [
          {
            "value": "zh-CN",
            "label": "简体中文"
          },
          {
            "value": "en-US",
            "label": "English"
          },
          {
            "value": "ja-JP",
            "label": "日本語"
          }
        ],
        "className": "w-28"
      }
    },
    {
      "id": "ftrLegalLinksBlock",
      "component": "div",
      "props": {
        "className": "flex items-center gap-2"
      },
      "children": [
        "ftrPrivacyLink",
        "ftrLinkDivider",
        "ftrTermsLink"
      ]
    },
    {
      "id": "ftrPrivacyLink",
      "component": "Button",
      "props": {
        "value": "隐私政策",
        "types": "link",
        "className": "text-sm"
      }
    },
    {
      "id": "ftrLinkDivider",
      "component": "span",
      "props": {
        "value": "|",
        "className": "text-sm text-on-surface-variant"
      }
    },
    {
      "id": "ftrTermsLink",
      "component": "Button",
      "props": {
        "value": "服务条款",
        "types": "link",
        "className": "text-sm"
      }
    }
  ],
  "state": {
    "brandLogoImage": "https://fpoimg.com/200x200?gradient=0067D1,004EA8&text_color=ffffff&text=LOGO",
    "brandName": "A2Cloud",
