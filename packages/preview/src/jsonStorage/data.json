{
  "rootId": "loginPageRoot",
  "elements": [
    {
      "id": "loginPageRoot",
      "component": "div",
      "props": {
        "className": "flex flex-row w-full h-screen"
      },
      "children": [
        "loginBrandSlot",
        "loginFormSlot"
      ]
    },
    {
      "id": "loginBrandSlot",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center justify-center w-[40%] h-full bg-gradient-to-br from-[#1A1A2E] to-[#16213E] text-white"
      },
      "children": [
        "brandInnerWrapper"
      ]
    },
    {
      "id": "loginFormSlot",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center justify-center w-[60%] h-full bg-surface"
      },
      "children": [
        "formCardWrapper"
      ]
    },
    {
      "id": "brandInnerWrapper",
      "component": "div",
      "props": {
        "className": "w-full h-full relative flex flex-col items-center justify-center"
      },
      "children": [
        "brandBgImage",
        "brandTopBar",
        "brandCenterContent",
        "brandBottomBar"
      ]
    },
    {
      "id": "brandBgImage",
      "component": "img",
      "props": {
        "src": {
          "path": "/brandBackgroundImage"
        },
        "alt": "品牌背景",
        "className": "absolute inset-0 w-full h-full object-cover opacity-10"
      }
    },
    {
      "id": "brandTopBar",
      "component": "div",
      "props": {
        "className": "w-full flex justify-end px-6 pt-5 relative z-10"
      },
      "children": [
        "brandLangSelect"
      ]
    },
    {
      "id": "brandLangSelect",
      "component": "Select",
      "props": {
        "value": {
          "path": "/brandCurrentLocale"
        },
        "options": [
          {
            "value": "zh-CN",
            "label": "简体中文"
          },
          {
            "value": "en-US",
            "label": "English (US)"
          },
          {
            "value": "ja-JP",
            "label": "日本語"
          },
          {
            "value": "ko-KR",
            "label": "한국어"
          },
          {
            "value": "fr-FR",
            "label": "Français"
          }
        ],
        "className": "w-40 bg-white/10 border-white/20 text-white",
        "placeholder": "选择语言"
      }
    },
    {
      "id": "brandCenterContent",
      "component": "div",
      "props": {
        "className": "flex-1 flex flex-col items-center justify-center gap-5 relative z-10"
      },
      "children": [
        "brandLogoIcon",
        "brandSystemName",
        "brandSloganRow"
      ]
    },
    {
      "id": "brandLogoIcon",
      "component": "Icon",
      "props": {
        "name": {
          "path": "/brandLogoIcon"
        },
        "size": 64,
        "shape": "circle",
        "color": "inverse"
      }
    },
    {
      "id": "brandSystemName",
      "component": "h1",
      "props": {
        "className": "text-3xl font-bold text-white text-center",
        "value": {
          "path": "/brandSystemName"
        }
      }
    },
    {
      "id": "brandSloganRow",
      "component": "div",
      "props": {
        "className": "flex items-center gap-2"
      },
      "children": [
        "brandSloganIcon",
        "brandSloganText"
      ]
    },
    {
      "id": "brandSloganIcon",
      "component": "Icon",
      "props": {
        "name": {
          "path": "/brandSloganIcon"
        },
        "size": 20,
        "shape": "outline",
        "color": "inverse"
      }
    },
    {
      "id": "brandSloganText",
      "component": "p",
      "props": {
        "className": "text-base text-white/70 text-center",
        "value": {
          "path": "/brandSlogan"
        }
      }
    },
    {
      "id": "brandBottomBar",
      "component": "div",
      "props": {
        "className": "w-full flex flex-col items-center gap-0.5 pb-6 relative z-10"
      },
      "children": [
        "brandCopyright",
        "brandVersion"
      ]
    },
    {
      "id": "brandCopyright",
      "component": "span",
      "props": {
        "className": "text-xs text-white/50",
        "value": {
          "path": "/brandCopyright"
        }
      }
    },
    {
      "id": "brandVersion",
      "component": "span",
      "props": {
        "className": "text-xs text-white/40",
        "value": {
          "path": "/brandVersion"
        }
      }
    },
    {
      "id": "formCardWrapper",
      "component": "div",
      "props": {
        "className": "w-full max-w-md px-inset py-page"
      },
      "children": [
        "formCardContainer"
      ]
    },
    {
      "id": "formCardContainer",
      "component": "div",
      "props": {
        "className": "flex flex-col gap-stack bg-surface-container-highest rounded-xl shadow-card p-inset"
      },
      "children": [
        "formCardTitle",
        "formUsernameField",
        "formPasswordField",
        "formCaptchaField",
        "formRememberRow",
        "formLoginBtn",
        "formActionLinks",
        "formSocialDivider",
        "formSocialSection",
        "formCopyrightText",
        "formVersionText"
      ]
    },
    {
      "id": "formCardTitle",
      "component": "span",
      "props": {
        "className": "text-lg font-semibold text-on-surface text-center mb-1",
        "value": "欢迎登录"
      }
    },
    {
      "id": "formUsernameField",
      "component": "div",
      "props": {
        "className": "flex flex-col gap-1"
      },
      "children": [
        "formUsernameLabel",
        "formUsernameInput",
        "formUsernameHelper"
      ]
    },
    {
      "id": "formUsernameLabel",
      "component": "span",
      "props": {
        "className": "text-sm font-medium text-on-surface-variant",
        "value": "用户名/邮箱"
      }
    },
    {
      "id": "formUsernameInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/username"
        },
        "placeholder": "请输入用户名或注册邮箱",
        "prefix": "User",
        "className": "w-full"
      }
    },
    {
      "id": "formUsernameHelper",
      "component": "span",
      "props": {
        "className": "text-xs text-on-surface-variant",
        "value": "请输入用户名（至少3个字符）"
      }
    },
    {
      "id": "formPasswordField",
      "component": "div",
      "props": {
        "className": "flex flex-col gap-1"
      },
      "children": [
        "formPasswordLabel",
        "formPasswordInput",
        "formPasswordHelper"
      ]
    },
    {
      "id": "formPasswordLabel",
      "component": "span",
      "props": {
        "className": "text-sm font-medium text-on-surface-variant",
        "value": "密码"
      }
    },
    {
      "id": "formPasswordInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/password"
        },
        "placeholder": "请输入密码",
        "prefix": "Lock",
        "type": "password",
        "className": "w-full"
      }
    },
    {
      "id": "formPasswordHelper",
      "component": "span",
      "props": {
        "className": "text-xs text-on-surface-variant",
        "value": "请输入密码（至少6个字符）"
      }
    },
    {
      "id": "formCaptchaField",
      "component": "div",
      "props": {
        "className": "flex flex-col gap-1"
      },
      "children": [
        "formCaptchaLabel",
        "formCaptchaRow",
        "formCaptchaHelper"
      ]
    },
    {
      "id": "formCaptchaLabel",
      "component": "span",
      "props": {
        "className": "text-sm font-medium text-on-surface-variant",
        "value": "验证码"
      }
    },
    {
      "id": "formCaptchaRow",
      "component": "div",
      "props": {
        "className": "flex items-center gap-3"
      },
      "children": [
        "formCaptchaInput",
        "formCaptchaImage",
        "formCaptchaRefreshBtn"
      ]
    },
    {
      "id": "formCaptchaInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/captcha"
        },
        "placeholder": "输入验证码",
        "prefix": "ScanQrCode",
        "className": "flex-1"
      }
    },
    {
      "id": "formCaptchaImage",
      "component": "img",
      "props": {
        "src": "https://fpoimg.com/120x40?gradient=0067D1,004EA8&text_color=ffffff&text=CAPTCHA",
        "className": "h-10 w-auto rounded-md border border-base cursor-pointer",
        "alt": "验证码图片"
      }
    },
    {
      "id": "formCaptchaRefreshBtn",
      "component": "Button",
      "props": {
        "icon": "RefreshCw",
        "shape": "circle",
        "title": "刷新验证码",
        "className": "shrink-0"
      }
    },
    {
      "id": "formCaptchaHelper",
      "component": "span",
      "props": {
        "className": "text-xs text-on-surface-variant",
        "value": "请输入验证码"
      }
    },
    {
      "id": "formRememberRow",
      "component": "div",
      "props": {
        "className": "flex items-center"
      },
      "children": [
        "formRememberCheckbox"
      ]
    },
    {
      "id": "formRememberCheckbox",
      "component": "Checkbox",
      "props": {
        "checked": {
          "path": "/rememberMe"
        },
        "value": "记住此设备"
      }
    },
    {
      "id": "formLoginBtn",
      "component": "Button",
      "props": {
        "type": "primary",
        "icon": "LogIn",
        "value": "登 录",
        "loading": {
          "path": "/loginLoading"
        },
        "className": "w-full h-10 text-md font-medium"
      }
    },
    {
      "id": "formActionLinks",
      "component": "div",
      "props": {
        "className": "flex items-center justify-between -mt-1"
      },
      "children": [
        "formForgotPasswordBtn",
        "formRegisterBtn"
      ]
    },
    {
      "id": "formForgotPasswordBtn",
      "component": "Button",
      "props": {
        "type": "link",
        "icon": "HelpCircle",
        "value": "忘记密码？",
        "className": "text-md p-0 h-auto"
      }
    },
    {
      "id": "formRegisterBtn",
      "component": "Button",
      "props": {
        "type": "link",
        "icon": "UserPlus",
        "value": "立即注册",
        "className": "text-md p-0 h-auto"
      }
    },
    {
      "id": "formSocialDivider",
      "component": "Divider",
      "props": {
        "value": "其他方式登录",
        "className": "text-sm text-on-surface-variant my-2"
      }
    },
    {
      "id": "formSocialSection",
      "component": "div",
      "props": {
        "className": "flex items-center justify-center gap-6"
      },
      "children": {
        "path": "/socialLogin/providers",
        "componentId": "formSocialItem"
      }
    },
    {
      "id": "formSocialItem",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center gap-1"
      },
      "children": [
        "formSocialIconBtn",
        "formSocialLabel"
      ]
    },
    {
      "id": "formSocialIconBtn",
      "component": "Button",
      "props": {
        "shape": "circle",
        "icon": {
          "path": "icon"
        },
        "title": {
          "path": "tooltip"
        },
        "className": "w-10 h-10"
      }
    },
    {
      "id": "formSocialLabel",
      "component": "span",
      "props": {
        "className": "text-xs text-on-surface-variant",
        "value": {
          "path": "providerName"
        }
      }
    },
    {
      "id": "formCopyrightText",
      "component": "span",
      "props": {
        "className": "text-xs text-on-surface-variant text-center mt-4",
        "value": "© 2026 DeepVision Technology. All rights reserved."
      }
    },
    {
      "id": "formVersionText",
      "component": "span",
      "props": {
        "className": "text-xs text-on-surface-variant text-center",
        "value": "v4.2.1"
      }
    }
  ],
  "state": {
    "brandSystemName": "DataPulse 智能分析平台",
    "brandSlogan": "洞见数据价值，驱动业务决策",
    "brandSloganIcon": "Sparkles",
    "brandLogoIcon": "ShieldCheck",
    "brandBackgroundImage": "https://fpoimg.com/800x900?gradient=1A1A2E,16213E&text_color=ffffff&text=ACCESS",
    "brandCurrentLocale": "zh-CN",
    "brandLanguageOptions": [
      {
        "locale": "zh-CN",
        "label": "简体中文",
        "icon": "Languages"
      },
      {
        "locale": "en-US",
        "label": "English (US)",
        "icon": "Languages"
      },
      {
        "locale": "ja-JP",
        "label": "日本語",
        "icon": "Languages"
      },
      {
        "locale": "ko-KR",
        "label": "한국어",
        "icon": "Languages"
      },
      {
        "locale": "fr-FR",
        "label": "Français",
        "icon": "Languages"
      }
    ],
    "brandCopyright": "© 2026 DeepVision Technology. All rights reserved.",
    "brandVersion": "v4.2.1",
    "username": "",
    "password": "",
    "captcha": "",
    "rememberMe": true,
    "loginLoading": false,
    "socialLogin": {
      "providers": [
        {
          "providerName": "WeChat",
          "icon": "MessageCircle",
          "tooltip": "微信扫码登录"
        },
        {
          "providerName": "DingTalk",
          "icon": "Bell",
          "tooltip": "钉钉扫码登录"
        },
        {
          "providerName": "Lark",
          "icon": "Bird",
          "tooltip": "飞书扫码登录"
        },
        {
          "providerName": "EnterpriseSSO",
          "icon": "Building",
          "tooltip": "企业SSO单点登录"
        }
      ]
    }
  }
}