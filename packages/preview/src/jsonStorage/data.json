{
  "rootId": "loginPageContainer",
  "elements": [
    {
      "id": "loginPageContainer",
      "component": "div",
      "props": {
        "className": "flex flex-row min-h-screen relative bg-surface-container-lowest"
      },
      "children": [
        "brandingAreaContainer",
        "loginAreaContainer",
        "globalSettingsContainer"
      ]
    },
    {
      "id": "brandingAreaContainer",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center justify-center w-[45%]"
      },
      "children": [
        "brandLogoImage",
        "brandTitle",
        "brandSlogan",
        "brandCarousel"
      ]
    },
    {
      "id": "loginAreaContainer",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center justify-center w-[55%] bg-surface-container-highest shadow-sm"
      },
      "children": [
        "loginFormCard"
      ]
    },
    {
      "id": "globalSettingsContainer",
      "component": "div",
      "props": {
        "className": "absolute top-4 right-4 z-10 flex items-center gap-2 bg-surface-container-highest shadow-sm px-3 py-2 rounded-lg"
      },
      "children": [
        "globalLangIcon",
        "globalLangSelect",
        "globalThemeBtn"
      ]
    },
    {
      "id": "globalLangIcon",
      "component": "Icon",
      "props": {
        "name": "languages",
        "color": "primary",
        "shape": "outline",
        "className": "w-5 h-5"
      }
    },
    {
      "id": "globalLangSelect",
      "component": "Select",
      "props": {
        "value": {
          "path": "/currentLanguage"
        },
        "options": {
          "path": "/languageOptions"
        },
        "className": "w-28"
      }
    },
    {
      "id": "globalThemeBtn",
      "component": "Button",
      "props": {
        "icon": {
          "path": "/themeToggleIcon"
        }
      }
    },
    {
      "id": "brandLogoImage",
      "component": "img",
      "props": {
        "src": {
          "path": "/brandInfo/logoImage"
        },
        "className": "h-20 w-auto mb-6",
        "alt": "系统Logo"
      }
    },
    {
      "id": "brandTitle",
      "component": "span",
      "props": {
        "className": "text-3xl font-bold text-on-surface mb-2 text-center",
        "value": {
          "path": "/brandInfo/systemName"
        }
      }
    },
    {
      "id": "brandSlogan",
      "component": "span",
      "props": {
        "className": "text-lg text-on-surface-variant mb-10 text-center",
        "value": {
          "path": "/brandInfo/slogan"
        }
      }
    },
    {
      "id": "brandCarousel",
      "component": "Carousel",
      "props": {
        "arrows": true,
        "dotPlacement": "bottom",
        "className": "w-full max-w-lg rounded-xl overflow-hidden shadow-card"
      },
      "children": {
        "path": "/brandInfo/carouselSlides",
        "componentId": "brandSlide"
      }
    },
    {
      "id": "brandSlide",
      "component": "div",
      "props": {
        "className": "relative flex flex-col items-center justify-center rounded-xl overflow-hidden bg-surface-container-highest"
      },
      "children": [
        "brandSlideImage",
        "brandSlideContent"
      ]
    },
    {
      "id": "brandSlideImage",
      "component": "img",
      "props": {
        "src": {
          "path": "slideImage"
        },
        "className": "w-full h-56 object-cover",
        "alt": {
          "path": "slideTitle"
        }
      }
    },
    {
      "id": "brandSlideContent",
      "component": "div",
      "props": {
        "className": "flex flex-col items-center gap-2 p-6 text-center"
      },
      "children": [
        "brandSlideTitle",
        "brandSlideDesc"
      ]
    },
    {
      "id": "brandSlideTitle",
      "component": "span",
      "props": {
        "className": "text-xl font-semibold text-on-surface",
        "value": {
          "path": "slideTitle"
        }
      }
    },
    {
      "id": "brandSlideDesc",
      "component": "span",
      "props": {
        "className": "text-md text-on-surface-variant leading-relaxed",
        "value": {
          "path": "slideDescription"
        }
      }
    },
    {
      "id": "loginFormCard",
      "component": "div",
      "props": {
        "className": "w-full max-w-md px-8 py-8"
      },
      "children": [
        "loginCardHeader",
        "loginErrorAlert",
        "loginUsernameField",
        "loginPasswordField",
        "loginCaptchaField",
        "loginOptionsRow",
        "loginSubmitBtn",
        "loginRegisterRow",
        "loginDivider",
        "loginSsoContainer",
        "loginFooter"
      ]
    },
    {
      "id": "loginCardHeader",
      "component": "div",
      "props": {
        "className": "mb-6 text-center"
      },
      "children": [
        "loginCardTitle",
        "loginCardDesc"
      ]
    },
    {
      "id": "loginCardTitle",
      "component": "span",
      "props": {
        "value": {
          "path": "/cardTitle"
        },
        "className": "text-2xl font-bold text-on-surface block"
      }
    },
    {
      "id": "loginCardDesc",
      "component": "span",
      "props": {
        "value": {
          "path": "/cardDesc"
        },
        "className": "text-md text-on-surface-variant block mt-2"
      }
    },
    {
      "id": "loginErrorAlert",
      "component": "div",
      "props": {
        "className": "bg-error-container rounded-lg px-4 py-3 mb-4"
      },
      "children": [
        "loginErrorText"
      ]
    },
    {
      "id": "loginErrorText",
      "component": "span",
      "props": {
        "value": {
          "path": "/errorMessage"
        },
        "className": "text-sm text-on-error-container"
      }
    },
    {
      "id": "loginUsernameField",
      "component": "div",
      "props": {
        "className": "mb-4"
      },
      "children": [
        "loginUsernameLabel",
        "loginUsernameInput"
      ]
    },
    {
      "id": "loginUsernameLabel",
      "component": "label",
      "props": {
        "value": "用户名",
        "className": "text-sm font-medium text-on-surface block mb-1"
      }
    },
    {
      "id": "loginUsernameInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/username"
        },
        "placeholder": "请输入用户名",
        "prefix": "user",
        "size": "large",
        "className": "w-full"
      }
    },
    {
      "id": "loginPasswordField",
      "component": "div",
      "props": {
        "className": "mb-4"
      },
      "children": [
        "loginPasswordLabel",
        "loginPasswordInput"
      ]
    },
    {
      "id": "loginPasswordLabel",
      "component": "label",
      "props": {
        "value": "密码",
        "className": "text-sm font-medium text-on-surface block mb-1"
      }
    },
    {
      "id": "loginPasswordInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/password"
        },
        "placeholder": "请输入密码",
        "prefix": "lock",
        "password": true,
        "size": "large",
        "className": "w-full"
      }
    },
    {
      "id": "loginCaptchaField",
      "component": "div",
      "props": {
        "className": "mb-4"
      },
      "children": [
        "loginCaptchaLabel",
        "loginCaptchaRow"
      ]
    },
    {
      "id": "loginCaptchaLabel",
      "component": "label",
      "props": {
        "value": "验证码",
        "className": "text-sm font-medium text-on-surface block mb-1"
      }
    },
    {
      "id": "loginCaptchaRow",
      "component": "div",
      "props": {
        "className": "flex gap-3 items-start"
      },
      "children": [
        "loginCaptchaInput",
        "loginCaptchaRight"
      ]
    },
    {
      "id": "loginCaptchaInput",
      "component": "Input",
      "props": {
        "value": {
          "path": "/captcha"
        },
        "placeholder": "请输入验证码",
        "prefix": "shield-check",
        "maxLength": 5,
        "size": "large",
        "className": "flex-1"
      }
    },
    {
      "id": "loginCaptchaRight",
      "component": "div",
      "props": {
        "className": "flex items-center gap-2 shrink-0"
      },
      "children": [
        "loginCaptchaImg",
        "loginCaptchaRefresh"
      ]
    },
    {
      "id": "loginCaptchaImg",
      "component": "img",
      "props": {
        "src": {
          "path": "/captchaImage"
        },
        "alt": "验证码图片",
        "className": "h-10 w-auto rounded-md border border-base"
      }
    },
    {
      "id": "loginCaptchaRefresh",
      "component": "Button",
      "props": {
        "icon": "refresh-cw",
        "value": "换一张",
        "iconPlacement": "start",
        "types": "link",
        "className": "text-sm whitespace-nowrap"
      }
    },
    {
      "id": "loginOptionsRow",
      "component": "div",
      "props": {
        "className": "flex items-center justify-between mb-6"
      },
      "children": [
        "loginRememberCheckbox",
        "loginForgotLink"
      ]
    },
    {
      "id": "loginRememberCheckbox",
      "component": "Checkbox",
      "props": {
        "checked": {
          "path": "/rememberMe"
        },
        "label": "记住我"
      }
    },
    {
      "id": "loginForgotLink",
      "component": "a",
      "props": {
        "href": {
          "path": "/forgotPasswordUrl"
        },
        "value": "忘记密码？",
        "className": "text-sm text-primary hover:underline"
      }
    },
    {
      "id": "loginSubmitBtn",
      "component": "Button",
      "props": {
        "value": "登 录",
        "color": "primary",
        "size": "large",
        "className": "w-full h-11 text-lg font-medium"
      }
    },
    {
      "id": "loginRegisterRow",
      "component": "div",
      "props": {
        "className": "text-center mt-4"
      },
      "children": [
        "loginRegisterPrefix",
        "loginRegisterLink"
      ]
    },
    {
      "id": "loginRegisterPrefix",
      "component": "span",
      "props": {
        "value": "还没有账号？",
        "className": "text-sm text-on-surface-variant"
      }
    },
    {
      "id": "loginRegisterLink",
      "component": "a",
      "props": {
        "href": {
          "path": "/registerUrl"
        },
        "value": "立即注册",
        "className": "text-sm text-primary font-medium hover:underline ml-1"
      }
    },
    {
      "id": "loginDivider",
      "component": "Divider",
      "props": {
        "value": {
          "path": "/dividerText"
        },
        "titlePlacement": "center",
        "className": "my-6"
      }
    },
    {
      "id": "loginSsoContainer",
      "component": "div",
      "props": {
        "className": "flex justify-center gap-5"
      },
      "children": {
        "path": "/ssoProviders",
        "componentId": "loginSsoBtn"
      }
    },
    {
      "id": "loginSsoBtn",
      "component": "div",
      "props": {
        "className": "w-10 h-10 rounded-full overflow-hidden cursor-pointer hover:opacity-80 transition-opacity border border-base",
        "title": {
          "path": "name"
        }
      },
      "children": [
        "loginSsoBtnImg"
      ]
    },
    {
      "id": "loginSsoBtnImg",
      "component": "img",
      "props": {
        "src": {
          "path": "icon"
        },
        "alt": {
          "path": "name"
        },
        "className": "w-full h-full object-cover"
      }
    },
    {
      "id": "loginFooter",
      "component": "div",
      "props": {
        "className": "text-center mt-8 pt-6 border-t border-divider"
      },
      "children": [
        "loginFooterCopyright",
        "loginFooterIcp"
      ]
    },
    {
      "id": "loginFooterCopyright",
      "component": "span",
      "props": {
        "value": {
          "path": "/footerCopyright"
        },
        "className": "text-sm text-on-surface-variant block"
      }
    },
    {
      "id": "loginFooterIcp",
      "component": "span",
      "props": {
        "value": {
          "path": "/footerIcp"
        },
        "className": "text-sm text-on-surface-variant block mt-1"
      }
    }
  ],
  "state": {
