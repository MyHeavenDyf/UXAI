      ]
    },
    {
      "id": "altcConfirmDropdown",
      "component": "Dropdown",
      "props": {
        "trigger": [
          "click"
        ],
        "menu": [
          {
            "label": "确认告警",
            "key": "confirm_alert"
          },
          {
            "label": "确认并清除",
            "key": "confirm_clear"
          }
        ]
      },
      "children": [
        "altcConfirmBtn"
      ]
    },
    {
      "id": "altcConfirmBtn",
      "component": "Button",
      "props": {
        "value": "确认",
        "icon": "chevron-down",
        "iconPlacement": "end"
      }
    },
    {
      "id": "altcClearDropdown",
      "component": "Dropdown",
      "props": {
        "trigger": [
          "click"
        ],
        "menu": [
          {
            "label": "清除选中",
            "key": "clear_selected"
          },
          {
            "label": "清除全部",
            "key": "clear_all"
          }
        ]
      },
      "children": [
