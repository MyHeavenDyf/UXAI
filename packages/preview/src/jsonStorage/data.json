{
  "rootId": "rootContainer",
  "elements": [
    {
      "id": "rootContainer",
      "component": "div",
      "props": {
        "className": "flex flex-row min-h-screen bg-surface-container-lowest"
      },
      "children": [
        "rootLsb",
        "rootContentPanel"
      ]
    },
    {
      "id": "rootLsb",
      "component": "aside",
      "props": {
        "className": "w-62 flex flex-col shrink-0 overflow-y-auto bg-surface-container-highest shadow-sm"
      },
      "children": [
        "sbarLogoImg",
        "sbarCollapseBtn",
        "sbarMenu"
      ]
    },
    {
      "id": "rootContentPanel",
      "component": "div",
      "props": {
        "className": "flex flex-col flex-1 min-w-0"
      },
      "children": [
        "rootHeaderShell",
        "rootAltContentShell"
      ]
    },
    {
      "id": "rootHeaderShell",
      "component": "header",
      "props": {
        "className": "h-12 flex items-center justify-end gap-inline px-page shrink-0 bg-surface-container-highest shadow-sm"
      },
      "children": [
        "hdrSearchIcon",
        "hdrNotificationIcon",
        "hdrDocumentIcon",
        "hdrUserSection",
        "hdrHelpIcon"
      ]
    },
    {
      "id": "rootAltContentShell",
      "component": "main",
      "props": {
        "className": "flex-1 min-h-0 overflow-y-auto p-page"
      },
      "children": [
        "altcTitleBar",
        "altcCardContainer"
      ]
    },
    {
      "id": "sbarLogoImg",
      "component": "img",
      "props": {
        "src": {
          "path": "/logCompositeImage"
        },
        "alt": "Huawei DME IQ Logo",
        "className": "px-4 py-3"
      }
    },
    {
      "id": "sbarCollapseBtn",
      "component": "Button",
      "props": {
        "icon": {
          "path": "/collapseIcon"
        },
        "types": "link",
        "className": "self-start ml-2 mb-1"
      }
    },
    {
      "id": "sbarMenu",
      "component": "Menu",
      "props": {
        "mode": "vertical",
        "selectedKeys": {
          "path": "/selectedMenuKeys"
        },
        "openKeys": {
          "path": "/openMenuKeys"
        },
        "items": {
          "path": "/menuItems"
        },
        "className": "flex-1"
      }
    },
    {
      "id": "hdrSearchIcon",
      "component": "Icon",
      "props": {
        "name": "search",
        "shape": "outline",
        "className": "w-5 h-5 text-on-surface"
      }
    },
    {
      "id": "hdrNotificationIcon",
      "component": "Icon",
      "props": {
        "name": "bell",
        "shape": "outline",
        "className": "w-5 h-5 text-on-surface"
      }
    },
    {
      "id": "hdrDocumentIcon",
      "component": "Icon",
      "props": {
        "name": "file-text",
        "shape": "outline",
        "className": "w-5 h-5 text-on-surface"
      }
    },
    {
      "id": "hdrUserSection",
      "component": "div",
