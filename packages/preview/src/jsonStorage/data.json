      }
    ],
    "lgnFrmUsername": "",
    "lgnFrmPassword": "",
    "lgnFrmCaptcha": "",
    "lgnFrmRememberMe": false,
    "lgnFrmCardTitle": "用户登录",
    "lgnFrmFormTitle": "欢迎回来",
    "lgnFrmFormSubtitle": "请使用企业账号登录",
    "lgnFrmLoginBtnText": "登录",
