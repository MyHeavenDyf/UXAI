{
  "name": "TimelineItem",
  "type": "object",
  "$defs": {
    "DataBinding":{
			"type": "object",
			"description": "JSON Pointer state reference",
			"required": ["path"],
			"properties": {
				"path": {
					"type": "string",
					"description": "A JSON Pointer path to a value in the state",
					"examples": ["/value", "/form/value"]
				}
			}	
		},
    "SlotNode":{
			"type": "object",
			"required": ["componentId"],
			"description": "Slot binding: Reference to a specific child node.",
			"properties": {
				"componentId": {
					"type": "string",
					"description": "Unique ID for cross-referencing."
				}
			}
		}
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID for cross-referencing."
    },
    "component": {
      "type": "string",
      "const": "TimelineItem"
    },
    "props": {
      "type": "object",
      "properties": {
        "content": {
          "oneOf": [{
							"type": "string",
							"description": "Raw text content to render directly (e.g., 'Submit', 'Hello World')."
						},
						{
							"$ref": "#/$defs/DataBinding"
						},
						{
							"$ref": "#/$defs/SlotNode"
						}
					],
          "description": "Component payload. Can be raw literal text OR a structural node reference. "
        },
        "title": {
          "oneOf": [{
							"type": "string",
							"description": "Raw text content to render directly (e.g., 'Submit', 'Hello World')."
						},
						{
							"$ref": "#/$defs/DataBinding"
						},
						{
							"$ref": "#/$defs/SlotNode"
						}
					],
          "description": "Title of the item. Can be raw literal text OR a structural node reference. "
        },
        "icon": {
          "oneOf": [{
							"type": "string"
						},
						{
							"$ref": "#/$defs/DataBinding"
						}
					],
          "description": "Valid kebab-case Lucide icon matching the context (e.g., 'chevron-right')."
        },
        "color": {
          "oneOf": [{
							"type": "string"
						},
						{
							"$ref": "#/$defs/DataBinding"
						}
					],
          "description": "Semantic hex color matching context."
        },
        "placement": {
          "type": "string",
          "description": "Customizing the node position",
          "enum": ["start","end"],
          "default": "start"
        },
        "className": {
          "type": "string",
          "description": "Tailwind CSS classes for the component."
        }
      },
      "required": ["title","content"]
    }
  },
  "required": ["id","component","props"]
}