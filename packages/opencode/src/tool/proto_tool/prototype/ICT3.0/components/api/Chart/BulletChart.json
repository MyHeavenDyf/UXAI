{
  "name": "BulletChart",
  "description": "Bar chart component for displaying data with rectangular bars.",
  "type": "object",
  "$defs": {
    "DataBinding": {
      "type": "object",
      "description": "JSON Pointer state reference",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "description": "A JSON Pointer path to a value in the state",
          "examples": [
            "/users",
            "/form/name",
            "name",
            "role"
          ]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component cross-reference ID."
    },
    "component": {
      "type": "string",
      "const": "BulletChart"
    },
    "props": {
      "type": "object",
      "properties": {
        "option": {
          "type": "object",
          "properties": {
            "data": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                {
                  "$ref": "#/$defs/DataBinding"
                }
              ],
              "description": "Core chart data source (required)"
            },
            "xAxis": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "string",
                  "description": "Field name for X-axis dimension mapping"
                },
                "name": {
                  "type": "string",
                  "description": "Setting the X-axis Name"
                }
              },
              "required": ["data"],
              "description": "X-axis base configuration (required)"
            },
            "yAxisTitle": {
              "type": "string",
              "description": "MANDATORY: The visible title/label of the Y-axis. This must be a descriptive string (e.g., 'Revenue (USD)', 'Count').",
              "minLength": 1,
              "examples": ["Amount", "Sales Volume"]
            },
            "direction": {
              "type": "string",
              "enum": ["vertical", "horizontal"],
              "description": "BulletChart direction: vertical or horizontal"
            },
            "markLine": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "number",
                  "description": "markLine in Charts"
                },
                "name": {
                  "type": "string",
                  "enum": ["info", "error", "warning", "subwarning", "success"],
                  "description": "markLine state color"
                }
              },
              "required": ["data"],
              "description": "markline for displaying horizontal reference lines (required)"
            },
            "color": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "description": "Item color in hex format (e.g., '#F0F0F0')."
                  }
                },
                {
                  "$ref": "#/$defs/DataBinding"
                }
              ],
              "description": "Stick to default color groups. Override only upon explicit user request."
            }
          },
          "required": ["data", "xAxis", "yAxisTitle"]
        },
        "className": {
          "type": "string",
          "description": "Tailwind CSS classes for the component. Mandatory: width (w-) and height (h-) classes must be explicitly defined."
        }
      },
      "required": ["option", "className"]
    }
  },
  "required": ["id", "component", "props"]
}