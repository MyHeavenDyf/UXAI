{
	"name": "Steps",
	"type": "object",
	"$defs": {
		"DataBinding":{
			"type": "object",
			"description": "JSON Pointer state reference",
			"required": ["path"],
			"properties": {
				"path": {
					"type": "string",
					"description": "A JSON Pointer path to a value in the state",
					"examples": ["/value", "/form/value"]
				}
			}	
		},
		"StaticChildren":{
			"type": "array",
			"items": {
				"type": "string",
				"description": "The unique identifier for a component"
			},
			"description": "A static list of child component IDs."
		},
		"TemplateChildren":{
			"type": "object",
			"description": "A template for generating a dynamic list of children from a data model list. The `componentId` is the component to use as a template.",
			"properties": {
				"componentId": {
					"type": "string",
					"description": "The unique identifier for a component"
				},
				"path": {
					"type": "string",
					"description": "The path to the list of component property objects in the data model."
				}
			},
			"required": [
				"componentId",
				"path"
			]
		}
	},
	"properties": {
		"id": {
			"type": "string",
			"description": "Unique ID for cross-referencing."
		},
		"component": {
			"type": "string",
			"const": "Steps"
		},
		"props": {
			"type": "object",
			"properties": {
				"current": {
					"oneOf": [{
							"type": "number"
						},
						{
							"$ref": "#/$defs/DataBinding"
						}
					],
					"description": "Specify the current step."
				},
				"types": {
					"type": "string",
					"description": "Selection of Step Bar Type.",
					"enum": ["default", "dot", "inline", "navigation", "panel"],
					"default": "default"
				},
				"variant": {
					"type": "string",
					"enum": ["filled", "outlined"]
				},
				"orientation": {
					"type": "string",
					"enum": ["horizontal", "vertical"]
				},
				"status": {
					"type": "string",
					"enum": ["wait", "process", "finish", "error"]
				},
				"size": {
					"type": "string",
					"enum": ["large", "medium", "small"]
				},
				"className": {
					"type": "string",
					"description": "Tailwind CSS classes for the component."
				}
			},
			"required": ["current"]
		},
		"children": {
			"oneOf": [{
				"$ref": "#/$defs/StaticChildren"
			}, {
				"$ref": "#/$defs/TemplateChildren"
			}],
			"description": "Child nodes must be StepItem components. If using template loop format, the path must point to a stepItems data array."
		}

	},
	"required": ["id", "component", "props", "children"]
}