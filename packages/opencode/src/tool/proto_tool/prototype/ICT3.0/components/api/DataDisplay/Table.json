{
  "title": "Table",
  "description": "Declarative table component based on Antd Table variants.",
  "type": "object",
  "$defs": {
    "TemplateChildren": {
      "type": "object",
      "description": "A template for generating a dynamic list of children from a data model list. The `componentId` is the component to use as a template.",
      "properties": {
        "componentId": {
          "type": "string",
          "description": "The unique identifier for a component"
        },
        "path": {
          "type": "string",
          "description": "The path to the list of component property objects in the data model."
        }
      },
      "required": [
        "componentId",
        "path"
      ]
    },
    "DataBinding": {
      "type": "object",
      "description": "JSON Pointer state reference",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "description": "A JSON Pointer path to a value in the state",
          "examples": [
            "/users",
            "/form/name",
            "name",
            "role"
          ]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component cross-reference ID."
    },
    "component": {
      "type": "string",
      "const": "Table"
    },
    "props": {
      "type": "object",
      "required": [
        "rowKey",
        "columns",
        "dataSource"
      ],
      "properties": {
        "rowKey": {
          "type": "string",
          "description": "The field name in the row data to be used as the unique key."
        },
        "columns": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "title",
                  "dataIndex"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "dataIndex": {
                    "type": "string"
                  },
                  "align": {
                    "type": "string",
                    "enum": [
                      "left",
                      "right",
                      "center"
                    ]
                  },
                  "className": {
                    "type": "string"
                  },
                  "filters": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "fixed": {
                    "oneOf": [
                      {
                        "type": "string",
                        "enum": [
                          "start",
                          "end"
                        ]
                      },
                      {
                        "type": "boolean"
                      }
                    ]
                  },
                  "sort": {
                    "type": "boolean"
                  },
                  "width": {
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      }
                    ],
                    "description": "Only for fixed columns (fixed:'start'|'end'). Others must NOT set width."
                  },
                  "minWidth": {
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      }
                    ],
                    "description": "Only for long-text columns (desc, URL). Skip for short-content (status, tag, action)."
                  }
                }
              }
            },
            {
              "$ref": "#/$defs/DataBinding",
              "description": "Binding path to the table columns."
            }
          ]
        },
        "dataSource": {
          "$ref": "#/$defs/DataBinding",
          "description": "Binding path to the table data source."
        },
        "pagination": {
          "type": "boolean",
          "default": true,
          "description": "Whether to display pagination at the bottom of the table. Defaults to true; set to false to hide pagination and show all rows at once. The LLM does not need to generate pagination UI itself — it is handled automatically by the component."
        },
        "rowSelection": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "checkbox",
                "radio"
              ]
            },
            "selectedRowKeys": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "$ref": "#/$defs/DataBinding"
                }
              ]
            }
          }
        },
        "expandable": {
          "type": "object",
          "description": "Row expandable configuration.",
          "properties": {
            "expandedRowKeys": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "$ref": "#/$defs/DataBinding"
                }
              ],
              "description": "Keys of rows that support expanding."
            }
          }
        },
        "rowClassName": {
          "type": "string"
        },
        "className": {
          "type": "string"
        }
      }
    },
    "children": {
      "$ref": "#/$defs/TemplateChildren",
      "description": "A template for generating a dynamic list of children from a data model list. The componentId must be a TableRow."
    }
  },
  "required": [
    "id",
    "component",
    "props",
    "children"
  ]
}