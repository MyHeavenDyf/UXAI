{
  "name": "PatGauge",
  "description": "原生 JS + SVG 实现的半圆仪表盘组件，传入当前值和最大值，自动计算百分比并渲染带渐变弧线、刻度线、光效指示点和数字滚动动画。",
  "type": "object",
  "$defs": {
    "DataBinding": {
      "type": "object",
      "description": "JSON Pointer state reference",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "A JSON Pointer path to a value in the state",
          "examples": ["/cpuUsage", "/progress/percent"]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component cross-reference ID."
    },
    "component": {
      "type": "string",
      "const": "PatGauge"
    },
    "props": {
      "type": "object",
      "properties": {
        "value": {
          "oneOf": [
            { "type": "number" },
            { "$ref": "#/$defs/DataBinding" }
          ],
          "description": "当前数值，自动计算为 value/max 的百分比显示",
          "default": 0
        },
        "max": {
          "oneOf": [
            { "type": "number" },
            { "$ref": "#/$defs/DataBinding" }
          ],
          "description": "仪表盘的最大值，进度弧线满弧对应的数值",
          "default": 100
        },
        "className": {
          "type": "string",
          "description": "Tailwind CSS classes for the component."
        }
      },
      "required": ["value"]
    }
  },
  "required": ["id", "component", "props"]
}
