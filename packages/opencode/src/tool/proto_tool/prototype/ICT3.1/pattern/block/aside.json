    "rootId": "shellSidebar",
    "elements": [
        {
            "id": "shellSidebar",
            "component": "aside",
            "props": {
                "className": "w-[17.5rem] h-full bg-surface-container-highest shrink-0 shadow-sm"
            },
            "children": [
                "snSidebarHeader",
                "snSidebarDividerContainer",
                "snSidebarMenuContainer"
            ]
        },
        {
            "id": "snSidebarHeader",
            "component": "div",
            "props": {
                "className": "px-6 py-6 flex items-center"
            },
            "children": [
                "snSidebarTitleText"
            ]
        },
        {
            "id": "snSidebarTitleText",
            "component": "span",
            "props": {
                "className": "text-2xl font-bold text-on-surface",
                "value": {
                    "path": "/snSidebarTitle"
                }
            }
        },
        {
            "id": "snSidebarDividerContainer",
            "component": "div",
            "props": {
                "className": "px-6"
            },
            "children": [
                "snSidebarDivider"
            ]
        },
        {
            "id": "snSidebarDivider",
            "component": "Divider",
            "props": {
                "className": "mt-0 mb-0"
            }
        },
        {
            "id": "snSidebarMenuContainer",
            "component": "div",
            "props": {
                "className": "flex-1 overflow-y-auto px-2"
            },
            "children": [
                "snSidebarMenu"
            ]
        },
        {
            "id": "snSidebarMenu",
            "component": "Menu",
            "props": {
                "mode": "vertical",
                "selectedKeys": {
                    "path": "/snSelectedKeys"
                },
                "openKeys": {
                    "path": "/snOpenKeys"
                },
                "items": {
                    "path": "/snMenuItems"
                },
                "className": "border-none pt-0"
            }
        }
       
    ]
}