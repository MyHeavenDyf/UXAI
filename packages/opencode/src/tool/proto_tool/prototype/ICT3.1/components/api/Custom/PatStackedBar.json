{
  "name": "PatStackedBar",
  "description": "原生 JS 实现的横向堆叠条形图组件，通过四个状态数值自动计算比例并渲染带动画的条形图和图例。颜色内部固定：正常(绿)、告警(黄)、危险(橙)、错误(红)。",
  "type": "object",
  "$defs": {
    "DataBinding": {
      "type": "object",
      "description": "JSON Pointer state reference",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "A JSON Pointer path to a value in the state",
          "examples": ["/normalCount", "/stats/warning"]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component cross-reference ID."
    },
    "component": {
      "type": "string",
      "const": "PatStackedBar"
    },
    "props": {
      "type": "object",
      "properties": {
        "normal": {
          "oneOf": [
            { "type": "number" },
            { "$ref": "#/$defs/DataBinding" }
          ],
          "description": "正常状态的数量，对应绿色区块",
          "default": 0
        },
        "warning": {
          "oneOf": [
            { "type": "number" },
            { "$ref": "#/$defs/DataBinding" }
          ],
          "description": "告警状态的数量，对应黄色区块",
          "default": 0
        },
        "danger": {
          "oneOf": [
            { "type": "number" },
            { "$ref": "#/$defs/DataBinding" }
          ],
          "description": "危险状态的数量，对应橙色区块",
          "default": 0
        },
        "error": {
          "oneOf": [
            { "type": "number" },
            { "$ref": "#/$defs/DataBinding" }
          ],
          "description": "错误状态的数量，对应红色区块",
          "default": 0
        },
        "className": {
          "type": "string",
          "description": "Tailwind CSS classes for the component."
        }
      },
      "required": ["normal", "warning", "danger", "error"]
    }
  },
  "required": ["id", "component", "props"]
}
