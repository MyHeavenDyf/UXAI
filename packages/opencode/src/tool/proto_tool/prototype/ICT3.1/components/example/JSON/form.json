{
  "state": { "username": "","country": "","hobbies": [],"notification": true,"birthday": "" },
  "rootId": "formRoot",
  "elements": [
    { "id": "formRoot", "component": "div", "props": { "className": "p-6 max-w-lg mx-auto bg-white rounded-xl" }, "children": ["formTitle", "formContent", "submitBtn"] },
    { "id": "formTitle", "component": "h2", "props": { "value": "用户信息收集", "className": "text-xl font-bold text-slate-800 mb-6" } },
    { "id": "formContent", "component": "div", "props": { "className": "flex flex-col gap-5" }, "children": ["usernameField", "birthdayField", "countryField", "hobbiesField", "notificationField"] },
    { "id": "usernameField", "component": "div", "props": { "className": "flex flex-col gap-2" }, "children": ["usernameLabel", "usernameInput"] },
    { "id": "usernameLabel", "component": "span", "props": { "value": "用户名", "className": "text-sm font-medium text-slate-700" } },
    { "id": "usernameInput", "component": "Input", "props": { "value": { "path": "/username" }, "placeholder": "请输入用户名", "prefix": "User", "className": "w-full" } },
    { "id": "birthdayField", "component": "div", "props": { "className": "flex flex-col gap-2" }, "children": ["birthdayLabel", "birthdayPicker"] },
    { "id": "birthdayLabel", "component": "span", "props": { "value": "生日", "className": "text-sm font-medium text-slate-700" } },
    { "id": "birthdayPicker", "component": "DatePicker", "props": { "value": { "path": "/birthday" }, "placeholder": "选择日期", "picker": "date", "className": "w-full" } },
    { "id": "countryField", "component": "div", "props": { "className": "flex flex-col gap-2" }, "children": ["countryLabel", "countrySelect"] },
    { "id": "countryLabel", "component": "span", "props": { "value": "国家", "className": "text-sm font-medium text-slate-700" } },
    { "id": "countrySelect", "component": "Select", "props": { "value": { "path": "/country" }, "placeholder": "请选择国家", "options": [{ "label": "中国", "value": "cn" }, { "label": "美国", "value": "us" }, { "label": "日本", "value": "jp" }, { "label": "英国", "value": "uk" }], "className": "w-full" } },
    { "id": "hobbiesField", "component": "div", "props": { "className": "flex flex-col gap-2" }, "children": ["hobbiesLabel", "hobbiesCheckbox"] },
    { "id": "hobbiesLabel", "component": "span", "props": { "value": "爱好", "className": "text-sm font-medium text-slate-700" } },
    { "id": "hobbiesCheckbox", "component": "CheckboxGroup", "props": { "value": { "path": "/hobbies" }, "options": [{ "label": "阅读", "value": "reading" }, { "label": "运动", "value": "sports" }, { "label": "音乐", "value": "music" }, { "label": "旅行", "value": "travel" }] } },
    { "id": "notificationField", "component": "div", "props": { "className": "flex items-center justify-between" }, "children": ["notificationLabel", "notificationSwitch"] },
    { "id": "notificationLabel", "component": "span", "props": { "value": "接收通知", "className": "text-sm font-medium text-slate-700" } },
    { "id": "notificationSwitch", "component": "Switch", "props": { "value": { "path": "/notification" }, "checkedChildren": "开", "unCheckedChildren": "关" } },
    { "id": "submitBtn", "component": "Button", "props": { "value": "提交", "type": "primary", "className": "w-full mt-6" } }
  ]
}