{
  "name": "BarChart",
  "description": "Bar chart component for displaying data with rectangular bars.",
  "type": "object",
  "$defs": {
    "DataBinding": {
      "type": "object",
      "description": "JSON Pointer state reference",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "description": "A JSON Pointer path to a value in the state",
          "examples": [
            "/users",
            "/form/name",
            "name",
            "role"
          ]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component cross-reference ID."
    },
    "component": {
      "type": "string",
      "const": "BarChart"
    },
    "props": {
      "type": "object",
      "properties": {
        "option": {
          "type": "object",
          "properties": {
            "data": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                {
                  "$ref": "#/$defs/DataBinding"
                }
              ],
              "description": "Core chart data source (required)"
            },
            "lineOption": {
              "type": "object",
              "description": "Line chart options",
              "properties": {
                "dataName": {
                  "type": "array",
                  "description": "Data labels for the line chart"
                },
                "smooth": {
                  "type": "boolean",
                  "description": "Whether to display as smooth curve"
                }
              },
              "required": ["dataName"]
            },
            "barOption": {
              "type": "object",
              "description": "Bar chart options",
              "properties": {
                "dataName": {
                  "type": "array",
                  "description": "Data labels for the bar chart"
                },
                "label": {
                  "type": "object",
                  "description": "Label configuration for the bar chart",
                  "properties": {
                    "show": {
                      "type": "boolean"
                    }
                  }
                }
              },
              "required": ["dataName"]
            },
            "xAxis": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "string",
                  "description": "Field name for X-axis dimension mapping"
                }
              },
              "required": ["data"],
              "description": "X-axis base configuration (required)"
            },
            "yAxis": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "dataName": {
                    "type": "array",
                    "description": "Field name for Y-axis dimension mapping"
                  },
                  "name": {
                    "type": "string",
                    "description": "Title for the Y-axis"
                  },
                  "unit": {
                    "type": "string",
                    "description": "Unit for the Y-axis"
                  },
                  "position": {
                    "type": "string",
                    "enum": ["left", "right"],
                    "description": "Position of the Y-axis (left or right)"
                  }
                },
                "description": "Configuration for the dual Y-axes (required). Array length must be exactly 2 to support both left and right axes."
              }
            },
            "markLine": {
              "type": "object",
              "properties": {
                "top": {
                  "type": "number",
                  "description": "Upper threshold line"
                },
                "topUse": {
                  "type": "array",
                  "description": "Data labels for the upper threshold line"
                },
                "bottom": {
                  "type": "number",
                  "description": "Lower threshold line"
                },
                "bottomUse": {
                  "type": "array",
                  "description": "Data labels for the lower threshold line"
                }
              },
              "description": "markline for displaying horizontal reference lines"
            },
            "color":{
              "oneOf": [{
                  "type": "array",
                  "items": {
                    "type": "string",
                    "description": "Item color in hex format (e.g., '#F0F0F0')."
                  }
                },
                {
                  "$ref": "#/$defs/DataBinding"
                }
              ],
              "description": "Stick to default color groups. Override only upon explicit user request."
            }
          },
          "required": ["data", "xAxis", "yAxis", "barOption", "lineOption"]
        },
        "className": {
          "type": "string",
          "description": "Tailwind CSS classes for the component. Mandatory: width (w-) and height (h-) classes must be explicitly defined."
        }
      },
      "required": ["option", "className"]
    }
  },
  "required": ["id", "component", "props"]
}