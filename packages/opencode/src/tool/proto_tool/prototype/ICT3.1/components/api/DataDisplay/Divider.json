{
	"name": "Divider",
	"type": "object",
	"$defs": {
		"DataBinding":{
			"type": "object",
			"description": "JSON Pointer state reference",
			"required": ["path"],
			"properties": {
				"path": {
					"type": "string",
					"description": "A JSON Pointer path to a value in the state",
					"examples": ["/value", "/form/value"]
				}
			}	
		},
		"SlotNode":{
			"type": "object",
			"required": ["componentId"],
			"description": "Slot binding: Reference to a specific child node.",
			"properties": {
				"componentId": {
					"type": "string",
					"description": "Unique ID for cross-referencing."
				}
			}
		}
	},
	"description": "Used to separate the contents",
	"properties": {
		"id": {
			"type": "string",
			"description": "Unique ID for cross-referencing."
		},
		"component": {
			"type": "string",
			"const": "Divider"
		},
		"props": {
			"type": "object",
			"properties": {
				"value": {
					"oneOf": [{
							"type": "string",
							"description": "Raw text content to render directly (e.g., 'Submit', 'Hello World')."
						},
						{
							"$ref": "#/$defs/DataBinding"
						},
						{
							"$ref": "#/$defs/SlotNode"
						}
					],
					"description": "Content of the dividing line. Can be raw literal text OR a structural node reference."
				},
				"orientation": {
					"type": "string"
				},
				"size": {
					"type": "string",
					"enum": ["large", "medium", "small"]
				},
				"titlePlacement": {
					"type": "string",
					"enum": ["start", "end", "center"]
				},
				"variant": {
					"type": "string",
					"enum": ["dashed", "dotted", "solid"]
				},
				"className": {
					"type": "string",
					"description": "Tailwind CSS classes for the component."
				}
			},
			"required": []
		}
	},
	"required": ["id", "component", "props"]
}