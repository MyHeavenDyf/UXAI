{
  "name": "ScatterChart",
  "description": "Scatter chart component for plotting relationships between two variables.",
  "type": "object",
  "$defs": {
    "DataBinding": {
      "type": "object",
      "description": "JSON Pointer state reference",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "description": "A JSON Pointer path to a value in the state",
          "examples": [
            "/users",
            "/form/name",
            "name",
            "role"
          ]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component cross-reference ID."
    },
    "component": {
      "type": "string",
      "const": "ScatterChart"
    },
    "props": {
      "type": "object",
      "properties": {
        "option": {
          "type": "object",
          "properties": {
            "data": {
              "oneOf": [
                {
                  "type": "object",
                  "description": "Scatter series data object keyed by series name, e.g. { \"1990\": [[28604, 77], [31163, 77.4]] }"
                },
                {
                  "$ref": "#/$defs/DataBinding"
                }
              ],
              "description": "Core chart data source (required)"
            },
            "yAxisTitle": {
              "type": "string",
              "description": "MANDATORY: The visible title/label of the Y-axis. This must be a descriptive string (e.g., 'Revenue (USD)', 'Count').",
              "minLength": 1,
              "examples": [
                "Amount",
                "Sales Volume"
              ]
            },
            "markPoint": {
              "oneOf": [
                {
                  "type": "object",
                  "description": "Mark specific scatter points by series/group name. Each value must be a coordinate pair [x, y].",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    },
                    "minItems": 2,
                    "maxItems": 2
                  },
                  "examples": [
                    {
                      "1990": [
                        30000,
                        50
                      ]
                    }
                  ]
                },
                {
                  "$ref": "#/$defs/DataBinding"
                }
              ]
            },
            "color": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "description": "Item color in hex format (e.g., '#F0F0F0')."
                  }
                },
                {
                  "$ref": "#/$defs/DataBinding"
                }
              ],
              "description": "Stick to default color groups. Override only upon explicit user request."
            }
          },
          "required": ["data"]
        },
        "className": {
          "type": "string",
          "description": "Tailwind CSS classes for the component. Mandatory: width (w-) and height (h-) classes must be explicitly defined."
        }
      },
      "required": ["option","className"]
    }
  },
  "required": [
    "id",
    "component",
    "props"
  ]
}
