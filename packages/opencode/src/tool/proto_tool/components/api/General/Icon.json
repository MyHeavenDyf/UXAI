{
	"name": "Icon",
	"type": "object",
	"description": "MUST be a valid Lucide icon.",
	"$defs": {
		"DataBinding": {
			"type": "object",
			"description": "JSON Pointer state reference",
			"required": [
				"path"
			],
			"properties": {
				"path": {
					"type": "string",
					"description": "A JSON Pointer path to a value in the state",
					"examples": [
						"/value",
						"/form/value"
					]
				}
			}
		}
	},
	"properties": {
		"id": {
			"type": "string",
			"description": "Unique ID for cross-referencing."
		},
		"component": {
			"type": "string",
			"const": "Icon"
		},
		"props": {
			"type": "object",
			"properties": {
				"name": {
					"oneOf": [
						{
							"type": "string"
						},
						{
							"$ref": "#/$defs/DataBinding"
						}
					],
					"description": "Valid kebab-case Lucide icon name that semantically represents the surrounding content and context."
				},
				"color": {
					"description": "Semantic hex color matching context.",
					"oneOf": [
						{
							"type": "string",
							"pattern": "^(success|primary|error|default|warning|critical|inverse|#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3}))$"
						},
						{
							"$ref": "#/$defs/DataBinding"
						}
					]
				},
				"shape": {
					"type": "string",
					"description": "Icon background shape with auto-tinted color.",
					"enum": [
						"outline",
						"fill",
						"square",
						"circle"
					]
				},
				"className": {
					"type": "string",
					"description": "Tailwind CSS classes for the component.Mandatory: width (w-) and height (h-) classes must be explicitly defined."
				}
			},
			"required": [
				"name"
			]
		}
	},
	"required": [
		"id",
		"component",
		"props"
	]
}