{
	"name": "Badge",
	"type": "object",
	"$defs": {
		"DataBinding":{
			"type": "object",
			"description": "JSON Pointer state reference",
			"required": ["path"],
			"properties": {
				"path": {
					"type": "string",
					"description": "A JSON Pointer path to a value in the state",
					"examples": ["/value", "/form/value"]
				}
			}	
		}
	},
	"properties": {
		"id": {
			"type": "string",
			"description": "Unique ID for cross-referencing."
		},
		"component": {
			"type": "string",
			"const": "Badge"
		},
		"props": {
			"type": "object",
			"properties": {
				"color": {
					"type": "string",
					"pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
				},
				"count": {
					"oneOf": [{
							"type": "string"
						},
						{
							"type": "number"
						},
						{
							"$ref": "#/$defs/DataBinding"
						}
					],
					"description": "Displayed content"
				},
				"dot": {
					"type": "boolean"
				},
				"offset": {
					"type": "array",
					"items": {
						"type": "number"
					},
					"description": "Position offset for the status point. Must be an array of two numbers: [x, y].",
					"minItems": 2,
					"maxItems": 2
				},
				"overflowCount": {
					"type": "number"
				},
				"showZero": {
					"type": "boolean"
				},
				"status": {
					"type": "string",
					"enum": ["success", "processing", "default", "error", "warning"]
				},
				"className": {
					"type": "string",
					"description": "Tailwind CSS classes for the component."
				}
			},
			"required": ["count"]
		},
		"children": {
			"type": "array",
			"items": {
				"type": "string",
				"description": "The unique identifier for a component"
			},
			"description": "The element to be wrapped by the Badge. A static list of child component IDs. Note: The node ID count must be exactly 1;"
    }
	},
	"required": ["id", "component", "props", "children"]
}