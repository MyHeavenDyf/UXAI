# ============================================================
# packages/desktop — 环境变量示例
#
# 本文件仅作文档用途，不含真实域名，可提交 git（外网仓库）。
#
# ── 仓库提交规则 ────────────────────────────────────────────
#   外网仓库（当前）：禁止提交任何 .env* 文件（域名不得外泄）
#                    只提交本 .env.example 作为文档
#   内网仓库：        提交 .env，将公共域名配置进去，
#                    团队成员 clone 后无需手动创建即可直接运行
#
# ── 文件与命令对应关系 ───────────────────────────────────────
#   命令                      加载的 .env 文件
#   bun run dev               .env  +  .env.local
#   bun run build             .env  +  .env.local
#   bun run dev:beta          .env  +  .env.beta   +  .env.local
#   bun run build:beta        .env  +  .env.beta   +  .env.local
#   bun run dev:prod          .env  +  .env.prod   +  .env.local
#   bun run build:prod        .env  +  .env.prod   +  .env.local
#
#   优先级（高 → 低）：.env.local > .env.beta/.env.prod > .env
#
# ── 需手动创建的文件（均已 gitignore）───────────────────────
#   .env           外网开发时本地创建；内网仓库直接提交
#   .env.local     个人临时覆盖（可选）
#   .env.beta      beta 环境，需包含 OCTO_CHANNEL=beta + 业务域名
#   .env.prod      prod 环境，需包含 OCTO_CHANNEL=prod + 业务域名
#
# ── 变量类型 ─────────────────────────────────────────────────
#   [Vite 变量] VITE_* 前缀 — 写在上述 .env* 文件里，
#               渲染层通过 import.meta.env.VITE_XXX 读取；
#               读不到时代码做容错，不影响 dev/build 启动
#   [Shell 变量] 无 VITE_ 前缀 — electron.vite.config.ts 通过
#                loadEnv(mode) 从对应 .env.[mode] 文件读取，
#                跨平台（Mac/Windows）均可用，无需 shell 内联注入。
#                默认 dev/build 命令读 .env，需在 .env 里设置
#                OCTO_CHANNEL；:beta/:prod 命令读 .env.beta/.env.prod。
# ============================================================

# ----------------------------------------------------------------
# [Vite 变量] 业务接口（必填，读不到时功能降级，不崩溃）
# ----------------------------------------------------------------

# 通用接口 base URL
VITE_OCTO_BASE_URL=https://your-api-domain.example.com

# 打点 / 上报接口 base URL
VITE_OCTO_REPORT_BASE_URL=https://your-report-domain.example.com

# Insight 上传服务端点（可选，留空则功能自动降级）
VITE_OCTO_UPLOAD_ENDPOINT=

# ----------------------------------------------------------------
# [Vite 变量] Sentry（可选，CI / 生产构建时填写）
# ----------------------------------------------------------------
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=
# VITE_SENTRY_RELEASE=

# ----------------------------------------------------------------
# [Shell 变量] 构建渠道
# :beta/:prod 命令已内联注入，无需重复写。
# 默认 dev/build 命令不注入，必须在此显式设置，否则回退到 dev。
# 内网 .env 应设为 prod；外网本地 dev 可省略（默认 dev）。
# ----------------------------------------------------------------
OCTO_CHANNEL=prod

# ----------------------------------------------------------------
# [Shell 变量] Sentry sourcemap 上传（CI 用，本地开发不需要）
# ----------------------------------------------------------------
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
