# ============================================================
# packages/desktop — 环境变量示例
#
# 本文件仅作文档用途，不含真实域名，可提交 git（外网仓库）。
#
# ── 仓库提交规则 ────────────────────────────────────────────
#   外网仓库（当前）：禁止提交任何 .env* 文件（域名不得外泄）
#                    只提交本 .env.example 作为文档
#   内网仓库：        提交 .env，将公共域名配置进去，
#                    团队成员 clone 后无需手动创建即可直接运行
#
# ── 文件与命令对应关系 ───────────────────────────────────────
#   命令                      加载的 .env 文件
#   bun run dev               .env  +  .env.local
#   bun run build             .env  +  .env.local
#   bun run dev:beta          .env  +  .env.beta   +  .env.local
#   bun run build:beta        .env  +  .env.beta   +  .env.local
#   bun run dev:prod          .env  +  .env.prod   +  .env.local
#   bun run build:prod        .env  +  .env.prod   +  .env.local
#
#   优先级（高 → 低）：.env.local > .env.beta/.env.prod > .env
#
# ── 需手动创建的文件（均已 gitignore）───────────────────────
#   .env           外网开发时本地创建；内网仓库直接提交
#   .env.local     个人临时覆盖（可选）
#   .env.beta      beta 环境业务域名（VITE_*），由 --mode beta 加载
#   .env.prod      prod 环境业务域名（VITE_*），由 --mode prod 加载
#
# ── 变量类型 ─────────────────────────────────────────────────
#   [Vite 变量] VITE_* 前缀 — 写在上述 .env* 文件里，
#               渲染层通过 import.meta.env.VITE_XXX 读取；
#               读不到时代码做容错，不影响 dev/build 启动
#   [构建渠道] OCTO_CHANNEL 不写在任何 .env 文件里。它完全由命令决定：
#               dev:beta/dev:prod、build:beta/build:prod、package:*、
#               release:* 均用 cross-env 内联注入（跨平台，dev/build/
#               package/prebuild/predev 五处一致读到）。无后缀的 dev/build
#               缺省即 dev。（CI 通过 Actions env 直接设 OCTO_CHANNEL。）
# ============================================================

# ----------------------------------------------------------------
# [Vite 变量] 业务接口（必填，读不到时功能降级，不崩溃）
# ----------------------------------------------------------------

# 通用接口 base URL
VITE_OCTO_BASE_URL=https://your-api-domain.example.com

# 打点 / 上报接口 base URL
VITE_OCTO_REPORT_BASE_URL=https://your-report-domain.example.com

# Insight 上传服务端点（可选，留空则功能自动降级）
VITE_OCTO_UPLOAD_ENDPOINT=

# ----------------------------------------------------------------
# [server 侧变量] 内网知识库检索(chat 的 knowledge_search 工具,跑在 sidecar 进程)
# ----------------------------------------------------------------
# 非 VITE_ 前缀:供 server 侧使用,经 electron.vite define + createSidecarEnv 注入 sidecar。
# 独立配置(不复用 VITE_OCTO_BASE_URL,避免与渠道默认值耦合)。
# 内网验证期可在 .env.prod 里先填 beta 域名,生产上线再换 prod 域名。
# 留空则工具回落本地 mock(http://localhost:8787,见 packages/opencode/script/kb-mock-server.ts)。
OCTO_KB_BASE_URL=

# ----------------------------------------------------------------
# [server 侧变量] Insight uxr-tool MCP server 地址(跑在 sidecar 进程)
# ----------------------------------------------------------------
# 非 VITE_ 前缀:供 server 侧 builtin-mcp 使用,经 electron.vite define + createSidecarEnv 注入 sidecar。
# 形如 http://<ip>:<port>/mcp。内网验证期在 .env.prod 里填生产 IP,无需 export。
# 留空则回落代码内默认 beta IP(http://7.192.161.60:8005/mcp,见 packages/opencode/src/config/builtin-mcp.ts)。
OCTO_UXR_MCP_URL=

# ----------------------------------------------------------------
# [Vite 变量] Sentry（可选，CI / 生产构建时填写）
# ----------------------------------------------------------------
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=
# VITE_SENTRY_RELEASE=

# 注：构建渠道 OCTO_CHANNEL 不在 .env 配置，由命令（cross-env）决定，详见顶部说明。

# ----------------------------------------------------------------
# [Shell 变量] Sentry sourcemap 上传（CI 用，本地开发不需要）
# ----------------------------------------------------------------
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
